<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>

<!--
    Proxy Group Detail page layout.
    Displays individual proxies belonging to a proxy group as full-width rows.
    Navigated to by clicking a proxy group card in the Proxy Manager.
    Has a + button to add more proxies to the group.
    Includes Gmail-style pagination controls above the proxy list.
    Controller: ProxyGroupDetailController
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.nodriver4j.ui.controllers.ProxyGroupDetailController"
      styleClass="content-area"
      spacing="0">

    <!-- ==================== Page Header ==================== -->
    <HBox alignment="CENTER_LEFT" styleClass="page-header" spacing="12">

        <!-- Back Button -->
        <Button fx:id="backButton"
                styleClass="back-button"
                onAction="#onBackClicked">
            <graphic>
                <Label text="←"
                       style="-fx-text-fill: #e5e5e5; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </graphic>
        </Button>

        <!-- Title (populated dynamically by controller) -->
        <VBox>
            <Label fx:id="groupNameLabel" text="Proxy Group" styleClass="page-title"/>
            <Label fx:id="proxyCountLabel" text="0 proxies" styleClass="page-subtitle"/>
        </VBox>

        <!-- Spacer -->
        <Region HBox.hgrow="ALWAYS"/>

        <!-- Search Bar -->
        <HBox fx:id="searchBar" styleClass="search-bar" alignment="CENTER_LEFT">
            <TextField fx:id="searchField"
                       promptText="Search"
                       styleClass="search-field"/>
        </HBox>

        <!-- Add Proxies Button -->
        <Button fx:id="addButton"
                styleClass="add-button"
                onAction="#onAddClicked">
            <graphic>
                <Label text="+"
                       style="-fx-text-fill: #e5e5e5; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            </graphic>
        </Button>

    </HBox>

    <!-- ==================== Pagination Bar ==================== -->
    <HBox fx:id="paginationBar"
          alignment="CENTER_RIGHT"
          spacing="8"
          visible="false"
          managed="false">
        <padding>
            <Insets top="4" right="4" bottom="8" left="0"/>
        </padding>

        <!-- Range label: e.g. "1–50 of 847" -->
        <Label fx:id="pageRangeLabel"
               text=""
               styleClass="pagination-range-label"/>

        <!-- Previous Page -->
        <Button fx:id="prevPageButton"
                styleClass="pagination-arrow-button"
                onAction="#onPrevPageClicked">
            <graphic>
                <Label text="‹"
                       style="-fx-text-fill: #e5e5e5; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            </graphic>
        </Button>

        <!-- Next Page -->
        <Button fx:id="nextPageButton"
                styleClass="pagination-arrow-button"
                onAction="#onNextPageClicked">
            <graphic>
                <Label text="›"
                       style="-fx-text-fill: #e5e5e5; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            </graphic>
        </Button>

    </HBox>

    <!-- ==================== Content Area ==================== -->
    <StackPane VBox.vgrow="ALWAYS">

        <!-- Empty State (shown when no proxies) -->
        <VBox fx:id="emptyState"
              styleClass="empty-state"
              alignment="CENTER"
              visible="true"
              managed="true">

            <Label text="🌐" styleClass="empty-state-icon"/>
            <Label text="No Proxies" styleClass="empty-state-title"/>
            <Label text="Click the + button to add proxies to this group"
                   styleClass="empty-state-description"/>

        </VBox>

        <!-- Proxy List (shown when proxies exist) -->
        <ScrollPane fx:id="scrollPane"
                    fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    visible="false"
                    managed="false"
                    style="-fx-background-color: transparent;">

            <VBox fx:id="proxyList"
                  styleClass="proxy-list-container"
                  spacing="8">
                <padding>
                    <Insets top="0" right="0" bottom="16" left="0"/>
                </padding>

                <!-- ProxyRow components are added here dynamically -->

            </VBox>

        </ScrollPane>

    </StackPane>

</VBox>