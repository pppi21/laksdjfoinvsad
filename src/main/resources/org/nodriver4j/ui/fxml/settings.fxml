<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    Settings page layout.
    Controller: SettingsController
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.nodriver4j.ui.controllers.SettingsController"
      spacing="0"
      stylesheets="@../css/dark-theme.css">

    <!-- ==================== Page Header ==================== -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT">
        <Label text="Settings" styleClass="page-title"/>
    </HBox>

    <!-- ==================== Scrollable Content ==================== -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="32" style="-fx-padding: 0 0 24px 0;">

            <!-- ==================== Browser Section ==================== -->
            <VBox spacing="8">
                <Label text="Browser" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e5e5e5;"/>
                <Region style="-fx-background-color: #404040; -fx-pref-height: 1px; -fx-max-height: 1px;"/>

                <!-- Chrome Path -->
                <VBox styleClass="form-group">
                    <Label text="Chrome Executable Path" styleClass="form-label"/>
                    <TextField fx:id="chromePathField"
                               promptText="Path to patched Chrome executable"/>
                </VBox>
            </VBox>

            <!-- ==================== Captcha API Keys Section ==================== -->
            <VBox spacing="8">
                <Label text="Captcha API Keys" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e5e5e5;"/>
                <Region style="-fx-background-color: #404040; -fx-pref-height: 1px; -fx-max-height: 1px;"/>

                <!-- AutoSolve AI API Key -->
                <VBox styleClass="form-group">
                    <Label text="AutoSolve AI API Key" styleClass="form-label"/>
                    <TextField fx:id="autoSolveApiKeyField"
                               promptText="Enter your AutoSolve AI API key"/>
                </VBox>

                <!-- CapSolver API Key -->
                <VBox styleClass="form-group">
                    <Label text="CapSolver API Key" styleClass="form-label"/>
                    <TextField fx:id="capsolverApiKeyField"
                               promptText="Enter your CapSolver API key"/>
                </VBox>

                <!-- 2Captcha API Key -->
                <VBox styleClass="form-group">
                    <Label text="2Captcha API Key" styleClass="form-label"/>
                    <TextField fx:id="twoCaptchaApiKeyField"
                               promptText="Enter your 2Captcha API key"/>
                </VBox>
            </VBox>

            <!-- ==================== SMS Providers Section ==================== -->
            <VBox spacing="8">
                <Label text="SMS Providers" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e5e5e5;"/>
                <Region style="-fx-background-color: #404040; -fx-pref-height: 1px; -fx-max-height: 1px;"/>
                <Label text="Configure API keys for SMS verification providers"
                       style="-fx-font-size: 12px; -fx-text-fill: #737373; -fx-padding: 0 0 4px 0;"/>

                <!-- Provider Dropdown -->
                <VBox styleClass="form-group">
                    <Label text="Provider" styleClass="form-label"/>
                    <ComboBox fx:id="smsProviderComboBox"/>
                </VBox>

                <!-- Dynamic Fields Container (populated by controller) -->
                <VBox fx:id="smsFieldsContainer" spacing="0"/>
            </VBox>

            <!-- ==================== Paths Section (Read-Only) ==================== -->
            <VBox spacing="8">
                <Label text="Data Paths" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e5e5e5;"/>
                <Region style="-fx-background-color: #404040; -fx-pref-height: 1px; -fx-max-height: 1px;"/>
                <Label text="These paths are configured in settings.json"
                       style="-fx-font-size: 12px; -fx-text-fill: #737373; -fx-padding: 0 0 4px 0;"/>

                <!-- Fingerprints Path -->
                <VBox styleClass="form-group">
                    <Label text="Fingerprints File" styleClass="form-label"/>
                    <Label fx:id="fingerprintsPathLabel"
                           style="-fx-font-size: 13px; -fx-text-fill: #a3a3a3; -fx-font-family: 'Consolas', 'SF Mono', monospace;"/>
                </VBox>

                <!-- Userdata Base Path -->
                <VBox styleClass="form-group">
                    <Label text="Userdata Directory" styleClass="form-label"/>
                    <Label fx:id="userdataPathLabel"
                           style="-fx-font-size: 13px; -fx-text-fill: #a3a3a3; -fx-font-family: 'Consolas', 'SF Mono', monospace;"/>
                </VBox>
            </VBox>

            <!-- ==================== Save Button ==================== -->
            <HBox alignment="CENTER_LEFT">
                <Button fx:id="saveButton"
                        text="Save"
                        styleClass="button, primary"
                        onAction="#onSaveClicked"
                        prefWidth="100"/>
                <Label fx:id="saveStatusLabel"
                       style="-fx-font-size: 13px; -fx-padding: 0 0 0 12px;"
                       text=""/>
            </HBox>

        </VBox>
    </ScrollPane>

</VBox>
