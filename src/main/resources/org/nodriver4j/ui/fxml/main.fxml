<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Main application layout with sidebar navigation and content area.
    Controller: MainController
-->
<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.nodriver4j.ui.controllers.MainController"
      stylesheets="@../css/dark-theme.css">

    <!-- ==================== Sidebar ==================== -->
    <VBox styleClass="sidebar">

        <!-- App Logo Placeholder -->
        <VBox styleClass="sidebar-header" alignment="CENTER">
            <Region styleClass="logo-placeholder" prefWidth="48" prefHeight="48" maxWidth="48" maxHeight="48"/>
        </VBox>

        <!-- Navigation Items -->
        <VBox styleClass="sidebar-nav" fx:id="navContainer">

            <!-- Task Manager (Active by default) -->
            <HBox fx:id="navTasks"
                  styleClass="nav-item, active"
                  onMouseClicked="#onNavTasksClicked">
                <Label text="📋" styleClass="nav-icon"/>
                <Label text="Task Manager"/>
            </HBox>

            <!-- Profile Manager (Future) -->
            <HBox fx:id="navProfiles"
                  styleClass="nav-item"
                  onMouseClicked="#onNavProfilesClicked"
                  visible="true"
                  managed="true">
                <Label text="👤" styleClass="nav-icon"/>
                <Label text="Profiles"/>
            </HBox>

            <!-- Proxy Manager (Future) -->
            <HBox fx:id="navProxies"
                  styleClass="nav-item"
                  onMouseClicked="#onNavProxiesClicked"
                  visible="true"
                  managed="true">
                <Label text="🌐" styleClass="nav-icon"/>
                <Label text="Proxies"/>
            </HBox>

            <!-- Settings (Future) -->
            <HBox fx:id="navSettings"
                  styleClass="nav-item"
                  onMouseClicked="#onNavSettingsClicked"
                  visible="true"
                  managed="true">
                <Label text="⚙" styleClass="nav-icon"/>
                <Label text="Settings"/>
            </HBox>

        </VBox>

        <!-- Spacer to push version to bottom -->
        <VBox VBox.vgrow="ALWAYS"/>

        <!-- Version info at bottom -->
        <VBox alignment="CENTER" style="-fx-padding: 16px;">
            <Label text="v1.0.0" styleClass="muted" style="-fx-font-size: 12px;"/>
        </VBox>

    </VBox>

    <!-- ==================== Content Area ==================== -->
    <StackPane fx:id="contentArea"
               styleClass="content-area"
               HBox.hgrow="ALWAYS">
        <!-- Pages are loaded here dynamically -->
    </StackPane>

</HBox>
