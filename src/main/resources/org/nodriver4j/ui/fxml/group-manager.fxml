<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Shared group manager page layout.
    Used for Task Manager, Profile Manager, and Proxy Manager pages.
    Displays group cards in a grid with an empty state fallback.

    NOTE: No fx:controller attribute. The controller is set programmatically
    by MainController via loader.setController(...) before loading.

    All text labels have fx:id references so the controller can populate
    them with page-specific content at initialization time.

    Controller base class: GroupManagerController
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      styleClass="content-area"
      spacing="0">

    <!-- ==================== Page Header ==================== -->
    <HBox alignment="CENTER_LEFT" styleClass="page-header">

        <!-- Title and subtitle (populated by controller) -->
        <VBox>
            <Label fx:id="pageTitleLabel" styleClass="page-title"/>
            <Label fx:id="pageSubtitleLabel" styleClass="page-subtitle"/>
        </VBox>

        <!-- Spacer -->
        <Region HBox.hgrow="ALWAYS"/>

        <!-- Add Button -->
        <Button fx:id="addButton"
                styleClass="add-button"
                onAction="#onAddClicked">
            <graphic>
                <Label text="+"
                       style="-fx-text-fill: #e5e5e5; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            </graphic>
        </Button>

    </HBox>

    <!-- ==================== Content Area ==================== -->
    <StackPane VBox.vgrow="ALWAYS">

        <!-- Empty State (shown when no groups exist) -->
        <VBox fx:id="emptyState"
              styleClass="empty-state"
              alignment="CENTER"
              visible="true"
              managed="true">

            <Label fx:id="emptyStateIconLabel" styleClass="empty-state-icon"/>
            <Label fx:id="emptyStateTitleLabel" styleClass="empty-state-title"/>
            <Label fx:id="emptyStateDescLabel" styleClass="empty-state-description"/>

        </VBox>

        <!-- Card Grid (shown when groups exist) -->
        <ScrollPane fx:id="scrollPane"
                    fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    visible="false"
                    managed="false"
                    style="-fx-background-color: transparent;">

            <FlowPane fx:id="cardGrid"
                      styleClass="group-card-grid"
                      hgap="16"
                      vgap="16"
                      alignment="TOP_LEFT">
                <padding>
                    <Insets top="0" right="0" bottom="16" left="0"/>
                </padding>

                <!-- Group cards are added here dynamically by the controller -->

            </FlowPane>

        </ScrollPane>

    </StackPane>

</VBox>
