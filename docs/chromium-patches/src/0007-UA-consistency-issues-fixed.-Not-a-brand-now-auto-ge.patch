   std::string product = GetProductAndVersion();
 
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+
+  // Override the Chrome/X.X.X.X product token to match the spoofed brand.
+  if (command_line->HasSwitch(switches::kFingerprintBrandVersion) ||
+      command_line->HasSwitch(switches::kFingerprintBrandVersionLong)) {
+    std::string brand = command_line->HasSwitch(switches::kFingerprintBrand)
+        ? command_line->GetSwitchValueASCII(switches::kFingerprintBrand)
+        : "Chrome";
+
+    if (brand == "Chrome") {
+      // Chrome uses the full version in the product token.
+      if (command_line->HasSwitch(switches::kFingerprintBrandVersionLong)) {
+        product = "Chrome/" + command_line->GetSwitchValueASCII(
+            switches::kFingerprintBrandVersionLong);
+      } else {
+        product = "Chrome/" + command_line->GetSwitchValueASCII(
+            switches::kFingerprintBrandVersion) + ".0.0.0";
+      }
+    } else {
+      // Non-Chrome brands (Edge, Opera, Vivaldi) use Chrome/MAJOR.0.0.0
+      product = "Chrome/" + command_line->GetSwitchValueASCII(
+          switches::kFingerprintBrandVersion) + ".0.0.0";
+    }
+  }
