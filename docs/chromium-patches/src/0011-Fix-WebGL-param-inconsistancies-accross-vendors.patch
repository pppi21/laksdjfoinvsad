From 929c41ca67fea6bc7dc9126a8abd2cbbd2b96b4d Mon Sep 17 00:00:00 2001
From: Leo Rodarte <leorodarte07@gmail.com>
Date: Tue, 24 Feb 2026 20:00:57 -0800
Subject: [PATCH 11/12] Fix WebGL param inconsistancies accross vendors

---
 .../blink/renderer/modules/webgl/BUILD.gn     |  1 +
 .../webgl/webgl2_rendering_context_base.cc    | 33 +++++++++++++++++--
 .../webgl/webgl_rendering_context_base.cc     | 30 ++++++++++++++++-
 3 files changed, 61 insertions(+), 3 deletions(-)

diff --git a/third_party/blink/renderer/modules/webgl/BUILD.gn b/third_party/blink/renderer/modules/webgl/BUILD.gn
index d611207944..9817e98206 100644
--- a/third_party/blink/renderer/modules/webgl/BUILD.gn
+++ b/third_party/blink/renderer/modules/webgl/BUILD.gn
@@ -195,6 +195,7 @@ blink_modules_sources("webgl") {
 
   public_deps = [ "//device/vr/public/mojom:vr_service_blink" ]
   deps = [
+    "//components/nodriver4j:nodriver4j_switches",
     "//device/vr/buildflags",
     "//gpu/command_buffer/client:gles2_implementation",
     "//gpu/command_buffer/client:gles2_interface",
diff --git a/third_party/blink/renderer/modules/webgl/webgl2_rendering_context_base.cc b/third_party/blink/renderer/modules/webgl/webgl2_rendering_context_base.cc
index 18aaa25ad7..b537542cbe 100644
--- a/third_party/blink/renderer/modules/webgl/webgl2_rendering_context_base.cc
+++ b/third_party/blink/renderer/modules/webgl/webgl2_rendering_context_base.cc
@@ -36,6 +36,8 @@
 #include "third_party/blink/renderer/modules/webgl/webgl_vertex_array_object.h"
 #include "third_party/blink/renderer/platform/heap/garbage_collected.h"
 #include "third_party/blink/renderer/platform/wtf/text/wtf_string.h"
+#include "base/command_line.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
 
 // Populates all parameters for texImage2D, including width, height, depth (set
 // to 1), and border. Many callers will need to zero-out border in order to
@@ -4808,8 +4810,25 @@ ScriptValue WebGL2RenderingContextBase::getParameter(ScriptState* script_state,
       return GetInt64Parameter(script_state, pname);
     case GL_MAX_COMBINED_UNIFORM_BLOCKS:
       return GetIntParameter(script_state, pname);
-    case GL_MAX_COMBINED_VERTEX_UNIFORM_COMPONENTS:
+    case GL_MAX_COMBINED_VERTEX_UNIFORM_COMPONENTS: {
+      const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+      if (cl->HasSwitch(switches::kFingerprintGpuVendor)) {
+        std::string vendor =
+            cl->GetSwitchValueASCII(switches::kFingerprintGpuVendor);
+        int target_components =
+            (vendor.find("NVIDIA") != std::string::npos) ? 16380 : 16384;
+        // Query real values and adjust combined to match target vendor
+        GLint real_components = 0;
+        ContextGL()->GetIntegerv(GL_MAX_VERTEX_UNIFORM_COMPONENTS,
+                                 &real_components);
+        GLint64 combined = 0;
+        ContextGL()->GetInteger64v(
+            GL_MAX_COMBINED_VERTEX_UNIFORM_COMPONENTS, &combined);
+        combined += (target_components - real_components);
+        return WebGLAny(script_state, combined);
+      }
       return GetInt64Parameter(script_state, pname);
+    }
     case GL_MAX_DRAW_BUFFERS:
       return GetIntParameter(script_state, pname);
     case GL_MAX_ELEMENT_INDEX:
@@ -4848,8 +4867,18 @@ ScriptValue WebGL2RenderingContextBase::getParameter(ScriptState* script_state,
       return GetIntParameter(script_state, pname);
     case GL_MAX_VERTEX_UNIFORM_BLOCKS:
       return GetIntParameter(script_state, pname);
-    case GL_MAX_VERTEX_UNIFORM_COMPONENTS:
+    case GL_MAX_VERTEX_UNIFORM_COMPONENTS: {
+      const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+      if (cl->HasSwitch(switches::kFingerprintGpuVendor)) {
+        std::string vendor =
+            cl->GetSwitchValueASCII(switches::kFingerprintGpuVendor);
+        if (vendor.find("NVIDIA") != std::string::npos) {
+          return WebGLAny(script_state, 16380);
+        }
+        return WebGLAny(script_state, 16384);
+      }
       return GetIntParameter(script_state, pname);
+    }
     case GL_MIN_PROGRAM_TEXEL_OFFSET:
       return GetIntParameter(script_state, pname);
     case GL_PACK_ROW_LENGTH:
diff --git a/third_party/blink/renderer/modules/webgl/webgl_rendering_context_base.cc b/third_party/blink/renderer/modules/webgl/webgl_rendering_context_base.cc
index 2e7e4c2a1c..b1f9d9730a 100644
--- a/third_party/blink/renderer/modules/webgl/webgl_rendering_context_base.cc
+++ b/third_party/blink/renderer/modules/webgl/webgl_rendering_context_base.cc
@@ -151,6 +151,8 @@
 #include "third_party/blink/renderer/platform/wtf/text/string_utf8_adaptor.h"
 #include "third_party/skia/include/core/SkImage.h"
 #include "ui/gfx/geometry/size.h"
+#include "base/command_line.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
 
 // Populates parameters from texImage2D except for border, width, height, and
 // depth (which are not present for all texImage2D functions).
@@ -3862,8 +3864,18 @@ ScriptValue WebGLRenderingContextBase::getParameter(ScriptState* script_state,
       return GetIntParameter(script_state, pname);
     case GL_MAX_VERTEX_TEXTURE_IMAGE_UNITS:
       return GetIntParameter(script_state, pname);
-    case GL_MAX_VERTEX_UNIFORM_VECTORS:
+    case GL_MAX_VERTEX_UNIFORM_VECTORS: {
+      const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+      if (cl->HasSwitch(switches::kFingerprintGpuVendor)) {
+        std::string vendor =
+            cl->GetSwitchValueASCII(switches::kFingerprintGpuVendor);
+        if (vendor.find("NVIDIA") != std::string::npos) {
+          return WebGLAny(script_state, 4095);
+        }
+        return WebGLAny(script_state, 4096);
+      }
       return GetIntParameter(script_state, pname);
+    }
     case GL_MAX_VIEWPORT_DIMS:
       return GetWebGLIntArrayParameter(script_state, pname);
     case GL_PACK_ALIGNMENT:
@@ -3975,6 +3987,14 @@ ScriptValue WebGLRenderingContextBase::getParameter(ScriptState* script_state,
       return ScriptValue::CreateNull(script_state->GetIsolate());
     case WebGLDebugRendererInfo::kUnmaskedRendererWebgl:
       if (ExtensionEnabled(kWebGLDebugRendererInfoName)) {
+        const base::CommandLine* command_line =
+            base::CommandLine::ForCurrentProcess();
+        if (command_line->HasSwitch(switches::kFingerprintGpuRenderer)) {
+          return WebGLAny(
+              script_state,
+              String(command_line->GetSwitchValueASCII(
+                  switches::kFingerprintGpuRenderer)));
+        }
         return WebGLAny(script_state,
                         String(ContextGL()->GetString(GL_RENDERER)));
       }
@@ -3984,6 +4004,14 @@ ScriptValue WebGLRenderingContextBase::getParameter(ScriptState* script_state,
       return ScriptValue::CreateNull(script_state->GetIsolate());
     case WebGLDebugRendererInfo::kUnmaskedVendorWebgl:
       if (ExtensionEnabled(kWebGLDebugRendererInfoName)) {
+        const base::CommandLine* command_line =
+            base::CommandLine::ForCurrentProcess();
+        if (command_line->HasSwitch(switches::kFingerprintGpuVendor)) {
+          return WebGLAny(
+              script_state,
+              String(command_line->GetSwitchValueASCII(
+                  switches::kFingerprintGpuVendor)));
+        }
         return WebGLAny(script_state,
                         String(ContextGL()->GetString(GL_VENDOR)));
       }
-- 
