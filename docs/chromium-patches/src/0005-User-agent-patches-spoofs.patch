+// Applies fingerprint overrides from command-line switches to UA metadata.
+// Modifies brand lists, version strings, and platform fields in-place.
+void BLINK_COMMON_EXPORT UpdateUserAgentMetadataFingerprint(
+    UserAgentMetadata* metadata);
+
+// Returns the brand suffix to append to the UA string (e.g., " Edg/131.0.0.0").
+// Returns empty string for Chrome or when no brand override is set.
+std::string BLINK_COMMON_EXPORT GetUserAgentFingerprintBrandInfo();
+
 }  // namespace blink
 
 #endif  // THIRD_PARTY_BLINK_PUBLIC_COMMON_USER_AGENT_USER_AGENT_METADATA_H_
