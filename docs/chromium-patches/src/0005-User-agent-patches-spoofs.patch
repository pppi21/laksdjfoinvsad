          a.ua_metadata_override == b.ua_metadata_override;
 }
 
+void UpdateUserAgentMetadataFingerprint(UserAgentMetadata* metadata) {
+  if (!metadata)
+    return;
+
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+
+  // --- Extract existing Chromium info from the metadata ---
+  std::string chromium_full_version;
+  std::string chromium_major_version;
+  for (const auto& entry : metadata->brand_full_version_list) {
+    if (entry.brand == "Chromium") {
+      chromium_full_version = entry.version;
+      size_t dot = chromium_full_version.find('.');
+      chromium_major_version = (dot != std::string::npos)
+                                   ? chromium_full_version.substr(0, dot)
+                                   : chromium_full_version;
+      break;
+    }
+  }
+
+  // --- Determine the display brand and its versions ---
+  std::string display_brand;
+  std::string brand_full_version;   // e.g. "145.0.7632.116"
+  std::string brand_major_version;  // e.g. "145"
+
+  if (command_line->HasSwitch(switches::kFingerprintBrand)) {
+    std::string brand_key =
+        command_line->GetSwitchValueASCII(switches::kFingerprintBrand);
+
+    // Map short keys to display names
+    if (brand_key == "Chrome") {
+      display_brand = "Google Chrome";
+    } else if (brand_key == "Edge") {
+      display_brand = "Microsoft Edge";
+    } else if (brand_key == "Opera") {
+      display_brand = "Opera";
+    } else if (brand_key == "Vivaldi") {
+      display_brand = "Vivaldi";
+    } else {
+      display_brand = brand_key;
+    }
+  } else {
+    // Default: present as Google Chrome
+    display_brand = "Google Chrome";
+  }
+
+  // Resolve full version (--fingerprint-brand-version-long takes priority)
+  if (command_line->HasSwitch(switches::kFingerprintBrandVersionLong)) {
+    brand_full_version = command_line->GetSwitchValueASCII(
+        switches::kFingerprintBrandVersionLong);
+  } else if (command_line->HasSwitch(switches::kFingerprintBrandVersion)) {
+    // Short version only — construct a synthetic full version
+    brand_full_version =
+        command_line->GetSwitchValueASCII(switches::kFingerprintBrandVersion) +
+        ".0.0.0";
+  } else {
+    // No override — use the Chromium version from the existing metadata
+    brand_full_version = chromium_full_version;
+  }
+
+  // Resolve major version (--fingerprint-brand-version takes priority)
+  if (command_line->HasSwitch(switches::kFingerprintBrandVersion)) {
+    brand_major_version =
+        command_line->GetSwitchValueASCII(switches::kFingerprintBrandVersion);
+  } else {
+    // Extract major from the full version
+    size_t dot = brand_full_version.find('.');
+    brand_major_version = (dot != std::string::npos)
+                              ? brand_full_version.substr(0, dot)
+                              : brand_full_version;
+  }
+
+  // For Chrome, the Chromium version must match the Chrome version.
+  // For other brands (Edge, Opera, etc.), Chromium keeps its original version.
+  bool is_chrome = (display_brand == "Google Chrome");
+  if (is_chrome) {
+    chromium_full_version = brand_full_version;
+    chromium_major_version = brand_major_version;
+  }
+
+  // --- Rebuild brand lists ---
+  // v145 order: Not:A-Brand, Google Chrome, Chromium
+  metadata->brand_version_list.clear();
+  metadata->brand_full_version_list.clear();
+
+  // Not:A-Brand (v145 format — colon separator, not semicolon)
+  metadata->brand_version_list.push_back({"Not:A-Brand", "99"});
+  metadata->brand_full_version_list.push_back({"Not:A-Brand", "99.0.0.0"});
+
+  // Display brand (Google Chrome, Microsoft Edge, etc.)
+  metadata->brand_version_list.push_back(
+      {display_brand, brand_major_version});
+  metadata->brand_full_version_list.push_back(
+      {display_brand, brand_full_version});
+
+  // Chromium
+  metadata->brand_version_list.push_back(
+      {"Chromium", chromium_major_version});
+  metadata->brand_full_version_list.push_back(
+      {"Chromium", chromium_full_version});
+
+  // Update top-level full version
+  metadata->full_version = brand_full_version;
+
+  // --- Platform overrides ---
+  if (command_line->HasSwitch(switches::kFingerprintPlatform)) {
+    std::string platform_key = base::ToLowerASCII(
+        command_line->GetSwitchValueASCII(switches::kFingerprintPlatform));
+
+    if (platform_key == "windows") {
+      metadata->platform = "Windows";
+      metadata->platform_version = "19.0.0";
+      metadata->architecture = "x86";
+      metadata->bitness = "64";
+      metadata->wow64 = false;
+    } else if (platform_key == "linux") {
+      metadata->platform = "Linux";
+      metadata->platform_version = "6.11.0";
+      metadata->architecture = "x86";
+      metadata->bitness = "64";
+      metadata->wow64 = false;
+    } else if (platform_key == "macos") {
+      metadata->platform = "macOS";
+      metadata->platform_version = "15.2.0";
+      metadata->architecture = "arm";
+      metadata->bitness = "64";
+      metadata->wow64 = false;
+    }
+
+    // Allow explicit platform version override
+    if (command_line->HasSwitch(switches::kFingerprintPlatformVersion)) {
+      std::string version_override = command_line->GetSwitchValueASCII(
+          switches::kFingerprintPlatformVersion);
+      if (!version_override.empty()) {
+        metadata->platform_version = version_override;
+      }
+    }
+  }
+}
+
+std::string GetUserAgentFingerprintBrandInfo() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+
+  if (!command_line->HasSwitch(switches::kFingerprintBrand))
+    return "";
+
+  std::string brand_key =
+      command_line->GetSwitchValueASCII(switches::kFingerprintBrand);
+
+  // Chrome doesn't append a brand suffix to the UA string
+  if (brand_key == "Chrome")
+    return "";
+
+  // Determine the version to use in the UA suffix
+  std::string version;
+  if (command_line->HasSwitch(switches::kFingerprintBrandVersionLong)) {
+    version = command_line->GetSwitchValueASCII(
+        switches::kFingerprintBrandVersionLong);
+  } else if (command_line->HasSwitch(switches::kFingerprintBrandVersion)) {
+    version = command_line->GetSwitchValueASCII(
+        switches::kFingerprintBrandVersion) + ".0.0.0";
+  }
+
+  // Map brand keys to their UA string tokens
+  if (brand_key == "Edge") {
+    return " Edg/" + (version.empty() ? "145.0.0.0" : version);
+  } else if (brand_key == "Opera") {
+    return " OPR/" + (version.empty() ? "123.0.0.0" : version);
+  } else if (brand_key == "Vivaldi") {
+    return " Vivaldi/" + (version.empty() ? "7.5.3735.66" : version);
+  } else if (!brand_key.empty()) {
+    return " " + brand_key + "/" + (version.empty() ? "0.0.0.0" : version);
+  }
+
+  return "";
+}
+
 }  // namespace blink
