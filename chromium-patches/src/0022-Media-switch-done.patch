 COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintDeviceMemory[];
 COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintHardwareConcurrency[];
 
+// Media device count override: "mics,webcams,speakers" (e.g. "1,1,3")
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintMedia[];
