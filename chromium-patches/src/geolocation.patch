+  // --- BEGIN geolocation spoofing ---
+  struct GeoSpoof {
+    double lat;
+    double lon;
+    double acc;
+    bool valid;
+  };
+  static const GeoSpoof geo_spoof = []() -> GeoSpoof {
+    const std::string value =
+        base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+            "fingerprint-geolocation");
+    if (value.empty())
+      return {0, 0, 0, false};
+    std::vector<std::string> parts = base::SplitString(
+        value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+    if (parts.size() < 2)
+      return {0, 0, 0, false};
+    double lat, lon;
+    if (!base::StringToDouble(parts[0], &lat) ||
+        !base::StringToDouble(parts[1], &lon))
+      return {0, 0, 0, false};
+    double acc = 100.0;
+    if (parts.size() >= 3)
+      base::StringToDouble(parts[2], &acc);
+    return {lat, lon, acc, true};
+  }();
+
+  if (geo_spoof.valid) {
+    is_running_ = true;
+    base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
