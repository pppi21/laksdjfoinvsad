+               double acc) {
+              auto position = mojom::Geoposition::New();
+              position->latitude = lat;
+              position->longitude = lon;
+              position->accuracy = acc;
+              position->timestamp = base::Time::Now();
+              self->location_update_callback_.Run(
+                  self, mojom::GeopositionResult::NewPosition(
+                            std::move(position)));
+            },
+            base::Unretained(this), geo_spoof.lat, geo_spoof.lon,
+            geo_spoof.acc));
+    return;
+  }
+  // --- END geolocation spoofing ---
