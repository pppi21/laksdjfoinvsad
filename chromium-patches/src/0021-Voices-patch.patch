+// components/nodriver4j/default_voices.h
+//
+// Provides static, per-platform voice lists used to spoof
+// speechSynthesis.getVoices() results. Activated automatically
+// when --fingerprint-platform is set.
+
+#ifndef COMPONENTS_NODRIVER4J_DEFAULT_VOICES_H_
+#define COMPONENTS_NODRIVER4J_DEFAULT_VOICES_H_
+
+#include <string>
+
+#include "base/component_export.h"
+#include "base/containers/span.h"
+
+namespace nodriver4j {
+
+// Represents a single SpeechSynthesisVoice entry.
+// In Chrome, voiceURI always equals the voice name, so a single
+// |name| field serves both purposes.
+struct DefaultVoiceEntry {
+  const char* name;  // Voice name and voiceURI
+  const char* lang;  // BCP 47 language tag (e.g. "en-US")
+  bool is_local;     // true = OS/local voice, false = Google remote voice
+  bool is_default;   // true = default voice for the platform
+};
+
+// Returns the full voice list (local + Google remote) for the given
+// platform string. Recognized values: "Windows", "macOS", "Linux".
+// Returns an empty span for unrecognized platforms or empty input,
+// which causes voice spoofing to be skipped (real voices pass through).
+COMPONENT_EXPORT(NODRIVER4J)
+base::span<const DefaultVoiceEntry> VoicesForPlatform(
+    const std::string& platform);
+
+// Returns the default fake-TTS speaking rate in characters per second.
+// Used to calculate the duration of fake speech completion events.
+COMPONENT_EXPORT(NODRIVER4J)
+float FakeSpeechCharsPerSecond();
+
+}  // namespace nodriver4j
+
+#endif  // COMPONENTS_NODRIVER4J_DEFAULT_VOICES_H_
