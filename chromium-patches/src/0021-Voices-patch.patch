 namespace blink {
 
@@ -88,10 +92,32 @@ SpeechSynthesis::SpeechSynthesis(LocalDOMWindow& window)
 void SpeechSynthesis::OnSetVoiceList(
     Vector<mojom::blink::SpeechSynthesisVoicePtr> mojom_voices) {
   voice_list_.clear();
-  for (auto& mojom_voice : mojom_voices) {
-    voice_list_.push_back(
-        MakeGarbageCollected<SpeechSynthesisVoice>(std::move(mojom_voice)));
+
+  // When --fingerprint-platform is set, replace the real OS voice list
+  // with a curated platform-appropriate set of fake voices.
+  std::string platform =
+      base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+          switches::kFingerprintPlatform);
+  auto fake_voices = nodriver4j::VoicesForPlatform(platform);
+
+  if (!fake_voices.empty()) {
+    for (const auto& entry : fake_voices) {
+      voice_list_.push_back(MakeGarbageCollected<SpeechSynthesisVoice>(
+          mojom::blink::SpeechSynthesisVoice::New(
+              String::FromUTF8(entry.name),  // voice_uri (same as name in Chrome)
+              String::FromUTF8(entry.name),  // name
+              String::FromUTF8(entry.lang),  // lang
+              entry.is_local,                // is_local_service
+              entry.is_default)));           // is_default
+    }
+  } else {
+    // No spoofing — pass through real voices unchanged.
+    for (auto& mojom_voice : mojom_voices) {
+      voice_list_.push_back(
+          MakeGarbageCollected<SpeechSynthesisVoice>(std::move(mojom_voice)));
+    }
   }
+
   VoicesDidChange();
 }
 
@@ -242,6 +268,55 @@ void SpeechSynthesis::StartSpeakingImmediately() {
   utterance->SetStartTime(millis / 1000.0);
   is_paused_ = false;
 
+  // When voice spoofing is active, all exposed voices are fake.
+  // We cannot forward to the real TTS engine (it doesn't know these voices),
+  // so we dispatch synthetic start/end events with realistic timing.
+  std::string platform =
+      base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+          switches::kFingerprintPlatform);
+  auto fake_voices = nodriver4j::VoicesForPlatform(platform);
+
+  if (!fake_voices.empty()) {
+    // Fire the "start" event synchronously (matches real TTS behavior —
+    // the start event fires almost immediately after speak() is called).
+    DidStartSpeaking(utterance);
+
+    // Calculate a plausible speaking duration based on text length and rate.
+    unsigned text_length = utterance->text().length();
+    float rate = static_cast<float>(utterance->rate());
+    if (rate <= 0.0f)
+      rate = 1.0f;
+    float duration_seconds = static_cast<float>(text_length) /
+                             (nodriver4j::FakeSpeechCharsPerSecond() * rate);
+
+    // Schedule the "end" event after the calculated duration.
+    // WrapWeakPersistent guards against GC of |this| (e.g. if the page
+    // navigates away). WrapPersistent prevents the utterance from being
+    // collected before the timer fires.
+    GetSupplementable()
+        ->GetTaskRunner(TaskType::kMiscPlatformAPI)
+        ->PostDelayedTask(
+            FROM_HERE,
+            base::BindOnce(
+                [](WeakPersistent<SpeechSynthesis> weak_self,
+                   Persistent<SpeechSynthesisUtterance> utt) {
+                  if (!weak_self)
+                    return;
+                  // Only complete if this utterance is still current.
+                  // If Cancel() was called, the queue is empty and we
+                  // should not fire spurious events.
+                  if (weak_self->CurrentSpeechUtterance() == utt.Get()) {
+                    weak_self->DidFinishSpeaking(
+                        utt.Get(),
+                        mojom::blink::SpeechSynthesisErrorCode::kNoError);
+                  }
+                },
+                WrapWeakPersistent(this), WrapPersistent(utterance)),
+            base::Seconds(duration_seconds));
+    return;
+  }
+
+  // Normal path — forward to the real TTS engine via mojom.
   if (TryEnsureMojomSynthesis())
     utterance->Start(this);
 }
