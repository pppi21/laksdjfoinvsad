+// ---------------------------------------------------------------------------
+// Platform selector
+// ---------------------------------------------------------------------------
+base::span<const DefaultVoiceEntry> VoicesForPlatform(
+    const std::string& platform) {
+  if (base::EqualsCaseInsensitiveASCII(platform, "windows")) {
+    return base::span<const DefaultVoiceEntry>(kWindowsVoices);
+  }
+  if (base::EqualsCaseInsensitiveASCII(platform, "macos")) {
+    return base::span<const DefaultVoiceEntry>(kMacOSVoices);
+  }
+  if (base::EqualsCaseInsensitiveASCII(platform, "linux")) {
+    return base::span<const DefaultVoiceEntry>(kLinuxVoices);
+  }
+  return {};
+}
+
+float FakeSpeechCharsPerSecond() {
+  // ~150 words per minute ≈ 12.5 characters per second.
+  // Matches the average English speaking rate and is consistent
+  // with Camoufox's default value.
+  return 12.5f;
+}
