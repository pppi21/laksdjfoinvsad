@@ -0,0 +1,45 @@
+// components\nodriver4j\nodriver4j_switches.cc
+#include "components/nodriver4j/nodriver4j_switches.h"
+
+namespace switches {
+
+// Enable fingerprinting deception for getClientRects and getBoundingClientRect
+const char kFingerprintingClientRectsNoise[] = "fingerprinting-client-rects-noise";
+
+// Enable fingerprinting deception for measureText
+const char kFingerprintingCanvasMeasureTextNoise[] = "fingerprinting-canvas-measuretext-noise";
+
+// Enable fingerprinting deception for Canvas image data
+const char kFingerprintingCanvasImageDataNoise[] = "fingerprinting-canvas-image-data-noise";
+
+// Specify the browser brand (e.g. "Google Chrome")
+const char kFingerprintBrand[] = "fingerprint-brand";
+
+// Specify the browser major version (e.g. "145")
+const char kFingerprintBrandVersion[] = "fingerprint-brand-version";
+
+// Specify the full browser version (e.g. "145.0.7309.92")
+const char kFingerprintBrandVersionLong[] = "fingerprint-brand-version-long";
+
+// Specify the GPU vendor string for WebGL
+const char kFingerprintGpuVendor[] = "fingerprint-gpu-vendor";
+
+// Specify the GPU renderer string for WebGL
+const char kFingerprintGpuRenderer[] = "fingerprint-gpu-renderer";
+
+// Specify the number of CPU cores for navigator.hardwareConcurrency
+const char kFingerprintHardwareConcurrency[] = "fingerprint-hardware-concurrency";
+
+// Specify the operating system (e.g. "Windows", "macOS", "Linux")
+const char kFingerprintPlatform[] = "fingerprint-platform";
+
+// Specify the operating system version (e.g. "15.0.0")
+const char kFingerprintPlatformVersion[] = "fingerprint-platform-version";
+
+// Seed for deterministic canvas fingerprint noise
+const char kCanvasFingerprint[] = "canvas-fingerprint";
+
+// Seed for deterministic audio fingerprint noise
+const char kAudioFingerprint[] = "audio-fingerprint";
+
+}  // namespace switches
\ No newline at end of file
diff --git a/components/nodriver4j/nodriver4j_switches.h b/components/nodriver4j/nodriver4j_switches.h
new file mode 100644
index 0000000000..afbf418ae2
--- /dev/null
+++ b/components/nodriver4j/nodriver4j_switches.h
@@ -0,0 +1,36 @@
+// components\nodriver4j\nodriver4j_switches.h
+#ifndef COMPONENTS_NODRIVER4J_NODRIVER4J_SWITCHES_H_
+#define COMPONENTS_NODRIVER4J_NODRIVER4J_SWITCHES_H_
+
+#include "base/component_export.h"
+
+namespace switches {
+
+// Bromite noise flags
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintingClientRectsNoise[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintingCanvasMeasureTextNoise[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintingCanvasImageDataNoise[];
+
+// Browser brand and version
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintBrand[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintBrandVersion[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintBrandVersionLong[];
+
+// GPU spoofing
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintGpuVendor[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintGpuRenderer[];
+
+// Hardware
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintHardwareConcurrency[];
+
+// OS spoofing
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintPlatform[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintPlatformVersion[];
+
+// Canvas and audio fingerprint seeds
+COMPONENT_EXPORT(NODRIVER4J) extern const char kCanvasFingerprint[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kAudioFingerprint[];
+
+}  // namespace switches
+
+#endif  // COMPONENTS_NODRIVER4J_NODRIVER4J_SWITCHES_H_
