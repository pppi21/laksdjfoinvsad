From f8e08ed8b6387cae6d6083b7dc9e1aae65fc7a06 Mon Sep 17 00:00:00 2001
From: Leo Rodarte <leorodarte07@gmail.com>
Date: Tue, 24 Feb 2026 15:02:29 -0800
Subject: [PATCH 08/31] fixed incorrect UA string

---
 .../embedder_support/user_agent_utils.cc       | 18 ++++--------------
 1 file changed, 4 insertions(+), 14 deletions(-)

diff --git a/components/embedder_support/user_agent_utils.cc b/components/embedder_support/user_agent_utils.cc
index da1f60cddb..653956c80e 100644
--- a/components/embedder_support/user_agent_utils.cc
+++ b/components/embedder_support/user_agent_utils.cc
@@ -228,20 +228,10 @@ std::string GetUserAgentInternal() {
         ? command_line->GetSwitchValueASCII(switches::kFingerprintBrand)
         : "Chrome";
 
-    if (brand == "Chrome") {
-      // Chrome uses the full version in the product token.
-      if (command_line->HasSwitch(switches::kFingerprintBrandVersionLong)) {
-        product = "Chrome/" + command_line->GetSwitchValueASCII(
-            switches::kFingerprintBrandVersionLong);
-      } else {
-        product = "Chrome/" + command_line->GetSwitchValueASCII(
-            switches::kFingerprintBrandVersion) + ".0.0.0";
-      }
-    } else {
-      // Non-Chrome brands (Edge, Opera, Vivaldi) use Chrome/MAJOR.0.0.0
-      product = "Chrome/" + command_line->GetSwitchValueASCII(
-          switches::kFingerprintBrandVersion) + ".0.0.0";
-    }
+    // UA string always uses the reduced format Chrome/MAJOR.0.0.0
+    // Full version only appears in client hints (Sec-CH-UA-Full-Version-List)
+    product = "Chrome/" + command_line->GetSwitchValueASCII(
+        switches::kFingerprintBrandVersion) + ".0.0.0";
   }
 
 #if BUILDFLAG(IS_ANDROID) || BUILDFLAG(IS_IOS)
