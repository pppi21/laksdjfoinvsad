 }
diff --git a/third_party/blink/renderer/modules/battery/battery_manager.cc b/third_party/blink/renderer/modules/battery/battery_manager.cc
index 51cdc75cee..fecaa596dc 100644
--- a/third_party/blink/renderer/modules/battery/battery_manager.cc
+++ b/third_party/blink/renderer/modules/battery/battery_manager.cc
@@ -13,6 +13,70 @@
 #include "third_party/blink/renderer/core/frame/navigator.h"
 #include "third_party/blink/renderer/core/frame/web_feature.h"
 #include "third_party/blink/renderer/modules/battery/battery_dispatcher.h"
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_split.h"
+#include "base/strings/string_util.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
+
+namespace {
+
+struct BatteryOverride {
+  bool charging;
+  double level;
+  double charging_time;
+  double discharging_time;
+};
+
+std::optional<BatteryOverride> ParseBatteryOverride() {
+  const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+
+  // Priority 1: explicit --fingerprint-battery values
+  if (cl->HasSwitch(switches::kFingerprintBattery)) {
+    std::string value =
+        cl->GetSwitchValueASCII(switches::kFingerprintBattery);
+    std::vector<std::string> parts = base::SplitString(
+        value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+    if (parts.size() != 4)
+      return std::nullopt;
+
+    BatteryOverride result;
+    std::string charging_str = base::ToLowerASCII(parts[0]);
+    result.charging = (charging_str == "true" || charging_str == "1");
+
+    if (!base::StringToDouble(parts[1], &result.level))
+      return std::nullopt;
+
+    if (base::ToLowerASCII(parts[2]) == "infinity") {
+      result.charging_time = std::numeric_limits<double>::infinity();
+    } else if (!base::StringToDouble(parts[2], &result.charging_time)) {
+      return std::nullopt;
+    }
+
+    if (base::ToLowerASCII(parts[3]) == "infinity") {
+      result.discharging_time = std::numeric_limits<double>::infinity();
+    } else if (!base::StringToDouble(parts[3], &result.discharging_time)) {
+      return std::nullopt;
+    }
+
+    return result;
+  }
+
+  // Priority 2: desktop defaults from --fingerprint-platform
+  if (cl->HasSwitch(switches::kFingerprintPlatform)) {
+    std::string platform = base::ToLowerASCII(
+        cl->GetSwitchValueASCII(switches::kFingerprintPlatform));
+
+    if (platform == "windows" || platform == "macos" || platform == "linux") {
+      return BatteryOverride{
+          true, 1.0, 0.0, std::numeric_limits<double>::infinity()};
+    }
+  }
+
+  return std::nullopt;
+}
+
+}  // namespace
 
 namespace blink {
 
@@ -80,18 +144,26 @@ ScriptPromise<BatteryManager> BatteryManager::StartRequest(
 }
 
 bool BatteryManager::charging() {
+  if (auto ovr = ParseBatteryOverride())
+    return ovr->charging;
   return battery_status_.Charging();
 }
 
 double BatteryManager::chargingTime() {
+  if (auto ovr = ParseBatteryOverride())
+    return ovr->charging_time;
   return battery_status_.charging_time().InSecondsF();
 }
 
 double BatteryManager::dischargingTime() {
+  if (auto ovr = ParseBatteryOverride())
+    return ovr->discharging_time;
   return battery_status_.discharging_time().InSecondsF();
 }
 
 double BatteryManager::level() {
+  if (auto ovr = ParseBatteryOverride())
+    return ovr->level;
   return battery_status_.Level();
 }
 
