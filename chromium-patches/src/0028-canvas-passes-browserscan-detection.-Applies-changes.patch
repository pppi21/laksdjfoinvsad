From 32535b8bda59bda084b2a73be33caad32b0c5cd8 Mon Sep 17 00:00:00 2001
From: Leo Rodarte <leorodarte07@gmail.com>
Date: Thu, 5 Mar 2026 15:12:00 -0800
Subject: [PATCH 28/46] canvas passes browserscan detection. Applies changes to
 arc(), quadraticCurveTo(), bezierCurveTo().

---
 .../blink/renderer/modules/canvas/BUILD.gn    |  1 +
 .../canvas2d/canvas_2d_recorder_context.cc    |  2 +
 .../modules/canvas/canvas2d/canvas_path.cc    | 43 +++++++++++++++++++
 .../platform/fonts/shaping/harfbuzz_shaper.cc |  1 +
 4 files changed, 47 insertions(+)

diff --git a/third_party/blink/renderer/modules/canvas/BUILD.gn b/third_party/blink/renderer/modules/canvas/BUILD.gn
index b341a6e159..32a14af7f9 100644
--- a/third_party/blink/renderer/modules/canvas/BUILD.gn
+++ b/third_party/blink/renderer/modules/canvas/BUILD.gn
@@ -58,6 +58,7 @@ blink_modules_sources("canvas") {
   ]
 
   deps = [
+    "//components/nodriver4j:nodriver4j_switches",
     "//third_party/blink/renderer/modules/webcodecs",
     "//third_party/blink/renderer/modules/webgpu",
   ]
diff --git a/third_party/blink/renderer/modules/canvas/canvas2d/canvas_2d_recorder_context.cc b/third_party/blink/renderer/modules/canvas/canvas2d/canvas_2d_recorder_context.cc
index 0630e01f64..fe125c85cb 100644
--- a/third_party/blink/renderer/modules/canvas/canvas2d/canvas_2d_recorder_context.cc
+++ b/third_party/blink/renderer/modules/canvas/canvas2d/canvas_2d_recorder_context.cc
@@ -153,6 +153,8 @@
 #include "ui/gfx/geometry/skia_conversions.h"
 #include "ui/gfx/geometry/vector2d_f.h"
 #include "v8/include/v8-local-handle.h"
+#include "base/command_line.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
 
 // UMA Histogram macros trigger a bug in IWYU.
 // https://github.com/include-what-you-use/include-what-you-use/issues/1546
diff --git a/third_party/blink/renderer/modules/canvas/canvas2d/canvas_path.cc b/third_party/blink/renderer/modules/canvas/canvas2d/canvas_path.cc
index 8c8b5f5cb0..4521fa2054 100644
--- a/third_party/blink/renderer/modules/canvas/canvas2d/canvas_path.cc
+++ b/third_party/blink/renderer/modules/canvas/canvas2d/canvas_path.cc
@@ -63,6 +63,8 @@
 #include "third_party/blink/renderer/platform/wtf/vector.h"
 #include "ui/gfx/geometry/rect_f.h"
 #include "ui/gfx/geometry/size_f.h"
+#include "base/command_line.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
 
 namespace blink {
 
@@ -104,6 +106,25 @@ void CanvasPath::closePath() {
   }
 }
 
+// Returns cached seed-based sub-pixel offsets.
+// Slight center shifts produce naturally different pixel
+// coverage indistinguishable from GPU/driver variation.
+static std::pair<float, float> GetCanvasNoiseOffset() {
+  static const auto cached = []() -> std::pair<float, float> {
+    const auto* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kCanvasFingerprint))
+      return {0.0f, 0.0f};
+    std::string seed_str =
+        cmd->GetSwitchValueASCII(switches::kCanvasFingerprint);
+    size_t hash_x = std::hash<std::string>{}(seed_str + "_cx");
+    size_t hash_y = std::hash<std::string>{}(seed_str + "_cy");
+    float dx = 0.01f + static_cast<float>(hash_x % 80) * 0.001f;
+    float dy = 0.01f + static_cast<float>(hash_y % 80) * 0.001f;
+    return {dx, dy};
+  }();
+  return cached;
+}
+
 void CanvasPath::moveTo(double double_x, double double_y) {
   float x = base::saturated_cast<float>(double_x);
   float y = base::saturated_cast<float>(double_y);
@@ -159,6 +180,13 @@ void CanvasPath::quadraticCurveTo(double double_cpx,
   float x = base::saturated_cast<float>(double_x);
   float y = base::saturated_cast<float>(double_y);
 
+  // Sub-pixel curve offset for canvas fingerprint noise
+  auto [noise_dx, noise_dy] = GetCanvasNoiseOffset();
+  cpx += noise_dx;
+  cpy += noise_dy;
+  x += noise_dx;
+  y += noise_dy;
+
   if (!std::isfinite(cpx) || !std::isfinite(cpy) || !std::isfinite(x) ||
       !std::isfinite(y)) [[unlikely]] {
     return;
@@ -191,6 +219,16 @@ void CanvasPath::bezierCurveTo(double double_cp1x,
   float cp2y = base::saturated_cast<float>(double_cp2y);
   float x = base::saturated_cast<float>(double_x);
   float y = base::saturated_cast<float>(double_y);
+
+  // Sub-pixel curve offset for canvas fingerprint noise
+  auto [noise_dx, noise_dy] = GetCanvasNoiseOffset();
+  cp1x += noise_dx;
+  cp1y += noise_dy;
+  cp2x += noise_dx;
+  cp2y += noise_dy;
+  x += noise_dx;
+  y += noise_dy;
+  
   if (!std::isfinite(cp1x) || !std::isfinite(cp1y) || !std::isfinite(cp2x) ||
       !std::isfinite(cp2y) || !std::isfinite(x) || !std::isfinite(y))
       [[unlikely]] {
@@ -433,6 +471,11 @@ void CanvasPath::arc(double double_x,
                      ExceptionState& exception_state) {
   float x = base::saturated_cast<float>(double_x);
   float y = base::saturated_cast<float>(double_y);
+  // Sub-pixel arc center offset for canvas fingerprint noise
+  auto [noise_dx, noise_dy] = GetCanvasNoiseOffset();
+  x += noise_dx;
+  y += noise_dy;
+
   float radius = base::saturated_cast<float>(double_radius);
   float start_angle = base::saturated_cast<float>(double_start_angle);
   float end_angle = base::saturated_cast<float>(double_end_angle);
diff --git a/third_party/blink/renderer/platform/fonts/shaping/harfbuzz_shaper.cc b/third_party/blink/renderer/platform/fonts/shaping/harfbuzz_shaper.cc
index 6b49bbb340..abdb3c03df 100644
--- a/third_party/blink/renderer/platform/fonts/shaping/harfbuzz_shaper.cc
+++ b/third_party/blink/renderer/platform/fonts/shaping/harfbuzz_shaper.cc
@@ -344,6 +344,7 @@ static void ApplyFontSpacingNoise(hb_buffer_t* buffer) {
   }
 }
 
+
 inline bool ShapeRange(hb_buffer_t* buffer,
                        const FontFeatureRanges& font_features,
                        const SimpleFontData* current_font,
