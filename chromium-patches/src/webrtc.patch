+// components/nodriver4j/webrtc_ip_spoofer.h
+//
+// Header-only utility for WebRTC IP spoofing. Provides functions to detect
+// whether spoofing is active, classify IPs as exempt (special/reserved),
+// and apply IP replacement to ICE candidate strings and SDP bodies.
+//
+// Usage: Include this header and call WebRtcIpSpoofer::SpoofCandidate() or
+// WebRtcIpSpoofer::SpoofSdp() at the relevant intercept points in Blink.
+
+#ifndef COMPONENTS_NODRIVER4J_WEBRTC_IP_SPOOFER_H_
+#define COMPONENTS_NODRIVER4J_WEBRTC_IP_SPOOFER_H_
+
+#include <string>
+#include <vector>
+
+#include "base/command_line.h"
+#include "base/no_destructor.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
+
+namespace nodriver4j {
+
+class WebRtcIpSpoofer {
+ public:
+  WebRtcIpSpoofer() = delete;
+
+  private:
+  struct Config {
+    std::string ipv4;
+    std::string ipv6;
+    bool active;
+  };
+
+  static inline const Config& GetConfig() {
+    static const base::NoDestructor<Config> config([]() -> Config {
+      const auto* cmd = base::CommandLine::ForCurrentProcess();
+      std::string v4 = cmd->GetSwitchValueASCII(switches::kWebrtcIP4);
+      std::string v6 = cmd->GetSwitchValueASCII(switches::kWebrtcIP6);
+      return {v4, v6, !v4.empty() || !v6.empty()};
+    }());
+    return *config;
+  }
+
+ public:
+  static inline bool IsActive() { return GetConfig().active; }
+  static inline const std::string& SpoofIPv4() { return GetConfig().ipv4; }
+  static inline const std::string& SpoofIPv6() { return GetConfig().ipv6; }
+
+  // Returns true if the address contains a colon (IPv6 notation).
+  static inline bool IsIPv6(const std::string& ip) {
+    return ip.find(':') != std::string::npos;
+  }
+
+  // Returns true if the IP is a reserved address that should not be replaced.
+  // Exempt addresses: any-address, loopback, and link-local ranges.
+  static inline bool IsSpecialIP(const std::string& ip) {
+    if (ip.empty())
+      return true;
+    // Any-address
+    if (ip == "0.0.0.0" || ip == "::")
+      return true;
+    // Loopback
+    if (ip == "127.0.0.1" || ip == "::1")
+      return true;
+    // Link-local IPv4 (169.254.0.0/16)
+    if (ip.compare(0, 8, "169.254.") == 0)
+      return true;
+    // Link-local IPv6 (fe80::/10)
+    if (ip.size() >= 4 && (ip[0] == 'f' || ip[0] == 'F') &&
+        (ip[1] == 'e' || ip[1] == 'E') && ip[2] == '8' && ip[3] == '0')
+      return true;
+    return false;
+  }
+
+  // Returns the spoof address for a given IP, or the original IP if:
+  // - The IP is a special/reserved address
+  // - No spoof is configured for this address family
+  static inline std::string ReplacementForIP(const std::string& ip) {
+    if (IsSpecialIP(ip))
+      return ip;
+    if (IsIPv6(ip)) {
+      std::string spoof = SpoofIPv6();
+      return spoof.empty() ? ip : spoof;
+    }
+    std::string spoof = SpoofIPv4();
+    return spoof.empty() ? ip : spoof;
+  }
+
+  // Replaces IP addresses in an ICE candidate string.
+  //
+  // Handles both bare candidates ("candidate:...") and SDP-prefixed
+  // candidates ("a=candidate:..."). Replaces the connection address at
+  // token index 4 and any related address following the "raddr" keyword.
+  //
+  // ICE candidate format (RFC 5245):
+  //   candidate:foundation component transport priority address port
+  //   typ type [raddr addr rport port] [generation ...]
+  static inline std::string SpoofCandidate(const std::string& candidate) {
+    if (!IsActive() || candidate.empty())
+      return candidate;
+
+    // Find connection address at token index 4
+    size_t pos = 0;
+    for (int i = 0; i < 4; ++i) {
+      pos = candidate.find(' ', pos);
+      if (pos == std::string::npos)
+        return candidate;
+      ++pos;
+    }
+    size_t end = candidate.find(' ', pos);
+    if (end == std::string::npos)
+      return candidate;
+
+    std::string result = candidate;
+    std::string addr = result.substr(pos, end - pos);
+    std::string replacement = ReplacementForIP(addr);
+    if (replacement != addr)
+      result.replace(pos, end - pos, replacement);
+
+    // Replace related address if present (follows "raddr" keyword)
+    size_t raddr_pos = result.find(" raddr ");
+    if (raddr_pos != std::string::npos) {
+      size_t addr_start = raddr_pos + 7;
+      size_t addr_end = result.find(' ', addr_start);
+      if (addr_end == std::string::npos)
+        addr_end = result.size();
+      addr = result.substr(addr_start, addr_end - addr_start);
+      replacement = ReplacementForIP(addr);
+      if (replacement != addr)
+        result.replace(addr_start, addr_end - addr_start, replacement);
+    }
+
+    return result;
+  }
+
+
+  // Replaces IP addresses in a full SDP body.
+  //
+  // Processes three types of SDP lines:
+  //   - a=candidate: lines — delegates to SpoofCandidate()
+  //   - c= connection lines — address at field 2 (c=IN IP4 <addr>)
+  //   - o= origin lines — address at token index 5
+  //     (o=<user> <id> <ver> IN IP4 <addr>)
+  //
+  // Preserves original line endings (\r\n or \n).
+  static inline std::string SpoofSdp(const std::string& sdp) {
+    if (!IsActive() || sdp.empty())
+      return sdp;
+
+    std::string result;
+    result.reserve(sdp.size());
+
+    size_t pos = 0;
+    while (pos < sdp.size()) {
+      size_t eol = sdp.find('\n', pos);
+      if (eol == std::string::npos)
+        eol = sdp.size();
+
+      bool is_candidate = (sdp.compare(pos, 12, "a=candidate:") == 0);
+      bool is_connection = (!is_candidate && sdp.compare(pos, 2, "c=") == 0);
+      bool is_origin = (!is_candidate && !is_connection &&
+                        sdp.compare(pos, 2, "o=") == 0);
+
+      if (!is_candidate && !is_connection && !is_origin) {
+        // Unmodified line — append raw bytes including line ending
+        size_t chunk_end = (eol < sdp.size()) ? eol + 1 : eol;
+        result.append(sdp, pos, chunk_end - pos);
+        pos = (eol < sdp.size()) ? eol + 1 : sdp.size();
+        continue;
+      }
+
+      // Extract line content without \r\n
+      size_t line_end = eol;
+      bool has_cr = (line_end > pos && sdp[line_end - 1] == '\r');
+      if (has_cr)
+        --line_end;
+      std::string line = sdp.substr(pos, line_end - pos);
+
+      if (is_candidate) {
+        line = SpoofCandidate(line);
+
+      } else if (is_connection) {
+        // c=IN IP4 <address> — address after second space
+        auto space1 = line.find(' ');
+        if (space1 != std::string::npos) {
+          auto space2 = line.find(' ', space1 + 1);
+          if (space2 != std::string::npos) {
+            std::string addr = line.substr(space2 + 1);
+            std::string replacement = ReplacementForIP(addr);
+            if (replacement != addr)
+              line.replace(space2 + 1, std::string::npos, replacement);
+          }
+        }
+
+      } else if (is_origin) {
+        // o=<user> <id> <ver> IN IP4 <address> — token index 5
+        size_t tpos = 0;
+        for (int i = 0; i < 5; ++i) {
+          tpos = line.find(' ', tpos);
+          if (tpos == std::string::npos)
+            break;
+          ++tpos;
+        }
+        if (tpos != std::string::npos && tpos < line.size()) {
+          size_t tend = line.find(' ', tpos);
+          if (tend == std::string::npos)
+            tend = line.size();
+          std::string addr = line.substr(tpos, tend - tpos);
+          std::string replacement = ReplacementForIP(addr);
+          if (replacement != addr)
+            line.replace(tpos, tend - tpos, replacement);
+        }
+      }
+
+      result += line;
+      if (has_cr)
+        result += '\r';
+      if (eol < sdp.size())
+        result += '\n';
+      pos = (eol < sdp.size()) ? eol + 1 : sdp.size();
+    }
+
+    return result;
+  }
+};
+
+}  // namespace nodriver4j
+
+#endif  // COMPONENTS_NODRIVER4J_WEBRTC_IP_SPOOFER_H_
