@@ -512,6 +513,26 @@ RTCIceCandidateStats* ToV8Stat(
   // Non-standard and obsolete stats.
   SET_STAT(webrtc_stat.is_remote, v8_stat->setIsRemote);
   SET_STAT(webrtc_stat.ip, v8_stat->setIp);
+
+  // Spoof IP fields in local candidate stats
+  if (nodriver4j::WebRtcIpSpoofer::IsActive()) {
+    if (webrtc_stat.address.has_value()) {
+      std::string spoofed = nodriver4j::WebRtcIpSpoofer::ReplacementForIP(
+          webrtc_stat.address.value());
+      v8_stat->setAddress(String::FromUTF8(spoofed));
+    }
+    if (webrtc_stat.ip.has_value()) {
+      std::string spoofed = nodriver4j::WebRtcIpSpoofer::ReplacementForIP(
+          webrtc_stat.ip.value());
+      v8_stat->setIp(String::FromUTF8(spoofed));
+    }
+    if (webrtc_stat.related_address.has_value()) {
+      std::string spoofed = nodriver4j::WebRtcIpSpoofer::ReplacementForIP(
+          webrtc_stat.related_address.value());
+      v8_stat->setRelatedAddress(String::FromUTF8(spoofed));
+    }
+  }
+
   return v8_stat;
 }
 
