 namespace blink {
 
@@ -73,6 +77,70 @@ String GetConsoleLogStringForWebHoldback() {
          "and so may be inaccurate";
 }
 
+struct ConnectionOverride {
+  V8ConnectionType::Enum connection_type;
+  V8EffectiveConnectionType::Enum effective_type;
+  double downlink_mbps;
+  uint32_t rtt_ms;
+  bool save_data;
+};
+
+std::optional<ConnectionOverride> ParseConnectionOverride() {
+  const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+  if (!cl->HasSwitch(::switches::kFingerprintConnection))
+    return std::nullopt;
+
+  std::string value =
+      cl->GetSwitchValueASCII(::switches::kFingerprintConnection);
+  std::vector<std::string> parts = base::SplitString(
+      value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+  if (parts.size() != 5)
+    return std::nullopt;
+
+  ConnectionOverride result;
+
+  // Parse effective type
+  if (parts[0] == "slow-2g")
+    result.effective_type = V8EffectiveConnectionType::Enum::kSlow2G;
+  else if (parts[0] == "2g")
+    result.effective_type = V8EffectiveConnectionType::Enum::k2G;
+  else if (parts[0] == "3g")
+    result.effective_type = V8EffectiveConnectionType::Enum::k3G;
+  else
+    result.effective_type = V8EffectiveConnectionType::Enum::k4G;
+
+  // Parse downlink
+  if (!base::StringToDouble(parts[1], &result.downlink_mbps))
+    return std::nullopt;
+
+  // Parse rtt
+  unsigned rtt;
+  if (!base::StringToUint(parts[2], &rtt))
+    return std::nullopt;
+  result.rtt_ms = rtt;
+
+  // Parse saveData
+  result.save_data = (parts[3] == "true");
+
+  // Parse connection type
+  if (parts[4] == "wifi")
+    result.connection_type = V8ConnectionType::Enum::kWifi;
+  else if (parts[4] == "ethernet")
+    result.connection_type = V8ConnectionType::Enum::kEthernet;
+  else if (parts[4] == "cellular")
+    result.connection_type = V8ConnectionType::Enum::kCellular;
+  else if (parts[4] == "bluetooth")
+    result.connection_type = V8ConnectionType::Enum::kBluetooth;
+  else if (parts[4] == "wimax")
+    result.connection_type = V8ConnectionType::Enum::kWimax;
+  else if (parts[4] == "none")
+    result.connection_type = V8ConnectionType::Enum::kNone;
+  else
+    result.connection_type = V8ConnectionType::Enum::kUnknown;
+
+  return result;
+}
+
 }  // namespace
 
