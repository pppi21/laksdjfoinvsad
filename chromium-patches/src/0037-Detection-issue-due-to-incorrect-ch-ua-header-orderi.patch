+struct FingerprintBrandConfig {
+  bool active;
+  std::string major_version;
+  std::string full_version;
+  std::string display_brand;
+};
+
+const FingerprintBrandConfig& GetFingerprintBrandConfig() {
+  static const base::NoDestructor<FingerprintBrandConfig> config([]() -> FingerprintBrandConfig {
+    const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+
+    bool has_ver = cl->HasSwitch(switches::kFingerprintBrandVersion);
+    bool has_ver_long = cl->HasSwitch(switches::kFingerprintBrandVersionLong);
+    bool has_brand = cl->HasSwitch(switches::kFingerprintBrand);
+
+    if (!has_ver && !has_ver_long && !has_brand)
+      return {false, "", "", ""};
+
+    // Resolve major version
+    std::string major;
+    if (has_ver) {
+      major = cl->GetSwitchValueASCII(switches::kFingerprintBrandVersion);
+    } else if (has_ver_long) {
+      std::string full = cl->GetSwitchValueASCII(
+          switches::kFingerprintBrandVersionLong);
+      size_t dot = full.find('.');
+      major = (dot != std::string::npos) ? full.substr(0, dot) : full;
+    } else {
+      major = std::string(version_info::GetMajorVersionNumber());
+    }
+
+    // Resolve full version
+    std::string full;
+    if (has_ver_long) {
+      full = cl->GetSwitchValueASCII(switches::kFingerprintBrandVersionLong);
+    } else if (has_ver) {
+      full = major + ".0.0.0";
+    } else {
+      full = std::string(version_info::GetVersionNumber());
+    }
+
+    // Resolve display brand
+    std::string brand = "Google Chrome";
+    if (has_brand) {
+      std::string key = cl->GetSwitchValueASCII(switches::kFingerprintBrand);
+      if (key == "Chrome") brand = "Google Chrome";
+      else if (key == "Edge") brand = "Microsoft Edge";
+      else if (key == "Opera") brand = "Opera";
+      else if (key == "Vivaldi") brand = "Vivaldi";
+      else brand = key;
+    }
+
+    return {true, major, full, brand};
+  }());
+  return *config;
+}
+
 const blink::UserAgentBrandList GetUserAgentBrandList(
     const std::string& major_version,
     const std::string& full_version,
     blink::UserAgentBrandVersionType output_version_type,
     std::optional<blink::UserAgentBrandVersion> additional_brand_version) {
+
+  const auto& fp = GetFingerprintBrandConfig();
+
+  const std::string& effective_major = fp.active ? fp.major_version : major_version;
+  const std::string& effective_full = fp.active ? fp.full_version : full_version;
+
   int major_version_number;
-  bool parse_result = base::StringToInt(major_version, &major_version_number);
+  bool parse_result = base::StringToInt(effective_major, &major_version_number);
   DCHECK(parse_result);
+
   std::optional<std::string> brand;
+  if (fp.active) {
+    brand = fp.display_brand;
+  } else {
 #if !BUILDFLAG(CHROMIUM_BRANDING)
-  brand = version_info::GetProductName();
+    brand = version_info::GetProductName();
 #endif
+  }
 
   std::string brand_version =
       output_version_type == blink::UserAgentBrandVersionType::kFullVersion
-          ? full_version
-          : major_version;
+          ? effective_full
+          : effective_major;
 
   return GenerateBrandVersionList(major_version_number, brand, brand_version,
                                   output_version_type,
@@ -675,12 +743,18 @@ blink::UserAgentMetadata GetUserAgentMetadata(bool only_low_entropy_ch) {
   metadata.mobile = GetMobileBitForUAMetadata();
   metadata.platform = GetPlatformForUAMetadata();
 
-  // For users providing a valid user-agent override via the command line:
-  // If kUACHOverrideBlank is enabled, set user-agent metadata with the
-  // default blank values, otherwise return the default UserAgentMetadata values
-  // to populate and send only the low entropy client hints.
-  // Notes: Sending low entropy hints with empty values may cause requests being
-  // blocked by web application firewall software, etc.
+  // Override low-entropy platform name if spoofing
+  switch (nodriver4j::GetSpoofedPlatform()) {
+    case nodriver4j::SpoofedPlatform::kWindows:
+      metadata.platform = "Windows"; break;
+    case nodriver4j::SpoofedPlatform::kLinux:
+      metadata.platform = "Linux"; break;
+    case nodriver4j::SpoofedPlatform::kMacOS:
+      metadata.platform = "macOS"; break;
+    case nodriver4j::SpoofedPlatform::kNone:
+      break;
+  }
+
   std::optional<std::string> custom_ua = GetUserAgentFromCommandLine();
   if (custom_ua.has_value()) {
     return base::FeatureList::IsEnabled(blink::features::kUACHOverrideBlank)
@@ -695,13 +769,52 @@ blink::UserAgentMetadata GetUserAgentMetadata(bool only_low_entropy_ch) {
   // High entropy client hints.
   metadata.brand_full_version_list =
       GetUserAgentBrandFullVersionListInternal(std::nullopt);
-  metadata.full_version = std::string(version_info::GetVersionNumber());
+
+  const auto& fp = GetFingerprintBrandConfig();
+  metadata.full_version = fp.active
+      ? fp.full_version
+      : std::string(version_info::GetVersionNumber());
+
   metadata.architecture = GetCpuArchitecture();
   metadata.model = BuildModelInfo();
   metadata.form_factors = GetFormFactorsClientHint(metadata, metadata.mobile);
   metadata.bitness = GetCpuBitness();
   metadata.wow64 = IsWoW64();
   metadata.platform_version = GetPlatformVersion();
+
+  // Override high-entropy platform fields if spoofing
+  switch (nodriver4j::GetSpoofedPlatform()) {
+    case nodriver4j::SpoofedPlatform::kWindows:
+      metadata.platform_version = "19.0.0";
+      metadata.architecture = "x86";
+      metadata.bitness = "64";
+      metadata.wow64 = false;
+      break;
+    case nodriver4j::SpoofedPlatform::kLinux:
+      metadata.platform_version = "6.11.0";
+      metadata.architecture = "x86";
+      metadata.bitness = "64";
+      metadata.wow64 = false;
+      break;
+    case nodriver4j::SpoofedPlatform::kMacOS:
+      metadata.platform_version = "15.2.0";
+      metadata.architecture = "arm";
+      metadata.bitness = "64";
+      metadata.wow64 = false;
+      break;
+    case nodriver4j::SpoofedPlatform::kNone:
+      break;
+  }
+
+  // Allow explicit platform version override
+  const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+  if (cl->HasSwitch(switches::kFingerprintPlatformVersion)) {
+    std::string v = cl->GetSwitchValueASCII(
+        switches::kFingerprintPlatformVersion);
+    if (!v.empty())
+      metadata.platform_version = v;
+  }
+
   return metadata;
 }
 
