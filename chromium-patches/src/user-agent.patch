+std::string GetUserAgentFingerprintBrandInfo() {
+  static const base::NoDestructor<std::string> cached([]() -> std::string {
+    const base::CommandLine* cl =
+        base::CommandLine::ForCurrentProcess();
+
+    if (!cl->HasSwitch(switches::kFingerprintBrand))
+      return "";
+
+    std::string brand_key =
+        cl->GetSwitchValueASCII(switches::kFingerprintBrand);
+
+    if (brand_key == "Chrome")
+      return "";
+
+    std::string version;
+    if (cl->HasSwitch(switches::kFingerprintBrandVersionLong)) {
+      version = cl->GetSwitchValueASCII(switches::kFingerprintBrandVersionLong);
+    } else if (cl->HasSwitch(switches::kFingerprintBrandVersion)) {
+      version = cl->GetSwitchValueASCII(switches::kFingerprintBrandVersion) +
+                ".0.0.0";
+    }
+
+    if (brand_key == "Edge")
+      return " Edg/" + (version.empty() ? "145.0.0.0" : version);
+    if (brand_key == "Opera")
+      return " OPR/" + (version.empty() ? "123.0.0.0" : version);
+    if (brand_key == "Vivaldi")
+      return " Vivaldi/" + (version.empty() ? "7.5.3735.66" : version);
+    if (!brand_key.empty())
+      return " " + brand_key + "/" + (version.empty() ? "0.0.0.0" : version);
+
+    return "";
+  }());
+  return *cached;
+}
+
 }  // namespace blink
