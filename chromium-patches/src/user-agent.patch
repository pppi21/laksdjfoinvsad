@@ -0,0 +1,36 @@
+#ifndef COMPONENTS_NODRIVER4J_PLATFORM_OVERRIDE_H_
+#define COMPONENTS_NODRIVER4J_PLATFORM_OVERRIDE_H_
+
+#include <string>
+
+#include "base/command_line.h"
+#include "base/strings/string_util.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
+
+namespace nodriver4j {
+
+enum class SpoofedPlatform {
+  kNone,
+  kWindows,
+  kLinux,
+  kMacOS,
+};
+
+inline SpoofedPlatform GetSpoofedPlatform() {
+  static const SpoofedPlatform platform = []() -> SpoofedPlatform {
+    const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+    if (!cl->HasSwitch(switches::kFingerprintPlatform))
+      return SpoofedPlatform::kNone;
+    std::string key = base::ToLowerASCII(
+        cl->GetSwitchValueASCII(switches::kFingerprintPlatform));
+    if (key == "windows") return SpoofedPlatform::kWindows;
+    if (key == "linux") return SpoofedPlatform::kLinux;
+    if (key == "macos") return SpoofedPlatform::kMacOS;
+    return SpoofedPlatform::kNone;
+  }();
+  return platform;
+}
+
+}  // namespace nodriver4j
+
+#endif  // COMPONENTS_NODRIVER4J_PLATFORM_OVERRIDE_H_
