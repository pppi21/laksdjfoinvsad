+  font_bounding_box_ascent_ *= (1.0 + factor);
+  font_bounding_box_descent_ *= (1.0 + factor);
+  actual_bounding_box_ascent_ *= (1.0 + factor);
+  actual_bounding_box_descent_ *= (1.0 + factor);
+  em_height_ascent_ *= (1.0 + factor);
+  em_height_descent_ *= (1.0 + factor);
+  baselines_->setAlphabetic(baselines_->alphabetic() * (1.0 + factor));
+  baselines_->setHanging(baselines_->hanging() * (1.0 + factor));
+  baselines_->setIdeographic(baselines_->ideographic() * (1.0 + factor));
+}
