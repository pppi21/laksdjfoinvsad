   return energy > 0;
 }
 
+struct AudioOverride {
+  float sample_rate;
+  double base_latency;
+  double output_latency;
+  uint32_t max_channel_count;
+};
+
+std::optional<AudioOverride> ParseAudioOverride() {
+  const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+
+  // Priority 1: explicit --fingerprint-audio-context values
+  if (cl->HasSwitch(switches::kFingerprintAudioContext)) {
+    std::string value =
+        cl->GetSwitchValueASCII(switches::kFingerprintAudioContext);
+    std::vector<std::string> parts = base::SplitString(
+        value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+    if (parts.size() != 4)
+      return std::nullopt;
+
+    AudioOverride result;
+    double sample_rate_d;
+    if (!base::StringToDouble(parts[0], &sample_rate_d) ||
+        !base::StringToDouble(parts[1], &result.base_latency) ||
+        !base::StringToDouble(parts[2], &result.output_latency))
+      return std::nullopt;
+
+    result.sample_rate = static_cast<float>(sample_rate_d);
+
+    unsigned max_ch;
+    if (!base::StringToUint(parts[3], &max_ch))
+      return std::nullopt;
+    result.max_channel_count = static_cast<uint32_t>(max_ch);
+
+    return result;
+  }
+
+  // Priority 2: OS-appropriate defaults from --fingerprint-platform
+  if (cl->HasSwitch(switches::kFingerprintPlatform)) {
+    std::string platform = base::ToLowerASCII(
+        cl->GetSwitchValueASCII(switches::kFingerprintPlatform));
+
+    if (platform == "macos") {
+      return AudioOverride{48000.0f, 0.005333, 0.0, 2};
+    }
+    if (platform == "windows" || platform == "linux") {
+      return AudioOverride{48000.0f, 0.01, 0.0, 2};
+    }
+  }
+
+  // Priority 3: no override, use real hardware values
+  return std::nullopt;
+}
+
 }  // namespace
 
