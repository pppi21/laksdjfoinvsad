+    "Noto Serif Hebrew",
+    "Noto Serif Kannada",
+    "Noto Serif Khmer",
+    "Noto Serif Khojki",
+    "Noto Serif Lao",
+    "Noto Serif Malayalam",
+    "Noto Serif Myanmar",
+    "Noto Serif NP Hmong",
+    "Noto Serif Sinhala",
+    "Noto Serif Tamil",
+    "Noto Serif Telugu",
+    "Noto Serif Thai",
+    "Noto Serif Tibetan",
+    "Noto Serif Yezidi",
+    "STIX Two Math",
+    "Tinos",
+    "Twemoji Mozilla"
+};
+
+// Builds a case-folded set from the appropriate platform font list.
+// Called once, result is cached for the process lifetime.
+const std::unordered_set<std::string>* BuildWhitelist() {
+  const auto* command_line = base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(kFingerprintPlatform))
+    return nullptr;
+
+   std::string platform = base::ToLowerASCII(
+      command_line->GetSwitchValueASCII(kFingerprintPlatform));
+
+  const char* const* fonts = nullptr;
+  size_t count = 0;
+
+  if (platform == "windows") {
+    fonts = kWindowsFonts;
+    count = sizeof(kWindowsFonts) / sizeof(kWindowsFonts[0]);
+  } else if (platform == "macos") {
+    fonts = kMacFonts;
+    count = sizeof(kMacFonts) / sizeof(kMacFonts[0]);
+  } else if (platform == "linux") {
+    fonts = kLinuxFonts;
+    count = sizeof(kLinuxFonts) / sizeof(kLinuxFonts[0]);
+  } else {
+    return nullptr;
+  }
+
+  auto* set = new std::unordered_set<std::string>();
+  set->reserve(count);
+  for (size_t i = 0; i < count; ++i) {
+    set->insert(base::ToLowerASCII(fonts[i]));
+  }
+  return set;
+}
+
+const std::unordered_set<std::string>* GetWhitelist() {
+  static const std::unordered_set<std::string>* cached = BuildWhitelist();
+  return cached;
+}
+
+}  // namespace
+
+bool IsFontBlocked(const std::string& family_name) {
+  const auto* whitelist = GetWhitelist();
+  if (!whitelist)
+    return false;
+
+  // Generic CSS families are always allowed.
+  std::string lower = base::ToLowerASCII(family_name);
+  for (const char* generic : kGenericFamilies) {
+    if (lower == generic)
+      return false;
+  }
+
+  return whitelist->find(lower) == whitelist->end();
+}
+
