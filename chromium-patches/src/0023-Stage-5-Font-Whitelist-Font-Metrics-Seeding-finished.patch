+// Returns a deterministic font spacing offset in hb_position_t (16.16 fixed-point),
+// derived from the --canvas-fingerprint seed via LCG. Computed once, cached for
+// the lifetime of the renderer process.
+static hb_position_t GetCachedFontSpacing() {
+  static const hb_position_t cached = []() -> hb_position_t {
+    const auto* command_line = base::CommandLine::ForCurrentProcess();
+    if (!command_line->HasSwitch(switches::kCanvasFingerprint))
+      return 0;
+    std::string seed_str =
+        command_line->GetSwitchValueASCII(switches::kCanvasFingerprint);
+    unsigned seed = 0;
+    if (!base::StringToUint(seed_str, &seed) || seed == 0)
+      return 0;
+    // LCG step to derive a spacing value
+    seed = (seed * 1103515245 + 12345) & 0x7fffffff;
+    // Map to [0, 0.1] pixel range
+    float spacing = (static_cast<float>(seed) / 2147483647.0f) * 0.1f;
+    // Convert to 16.16 fixed-point
+    return static_cast<hb_position_t>(spacing * (1 << 16));
+  }();
+  return cached;
+}
+
+// Applies a uniform per-glyph advance perturbation to defeat font metrics
+// fingerprinting. Adjusts x_advance for horizontal text, y_advance for vertical.
+static void ApplyFontSpacingNoise(hb_buffer_t* buffer) {
+  hb_position_t spacing = GetCachedFontSpacing();
+  if (spacing == 0)
+    return;
+
+  unsigned int glyph_count;
+  hb_glyph_position_t* positions =
+      hb_buffer_get_glyph_positions(buffer, &glyph_count);
+  bool is_vertical =
+      HB_DIRECTION_IS_VERTICAL(hb_buffer_get_direction(buffer));
+
+  for (unsigned int i = 0; i < glyph_count; ++i) {
+    if (is_vertical) {
+      positions[i].y_advance += spacing;
+    } else {
+      positions[i].x_advance += spacing;
+    }
+  }
+}
