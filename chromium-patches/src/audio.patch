+#ifndef COMPONENTS_NODRIVER4J_AUDIO_OVERRIDE_H_
+#define COMPONENTS_NODRIVER4J_AUDIO_OVERRIDE_H_
+
+#include "base/command_line.h"
+#include "base/component_export.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_split.h"
+#include "base/strings/string_util.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
+
+namespace nodriver4j {
+
+struct AudioOverride {
+  bool active;
+  float sample_rate;
+  double base_latency;
+  double output_latency;
+  uint32_t max_channel_count;
+};
+
+inline const AudioOverride& GetAudioOverride() {
+  static const AudioOverride ovr = []() -> AudioOverride {
+    const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+
+    if (cl->HasSwitch(switches::kFingerprintAudioContext)) {
+      std::string value =
+          cl->GetSwitchValueASCII(switches::kFingerprintAudioContext);
+      std::vector<std::string> parts = base::SplitString(
+          value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+      if (parts.size() != 4) {
+        return {false, 0, 0, 0, 0};
+      }
+
+      double sample_rate_d, base_lat, output_lat;
+      if (!base::StringToDouble(parts[0], &sample_rate_d) ||
+          !base::StringToDouble(parts[1], &base_lat) ||
+          !base::StringToDouble(parts[2], &output_lat)) {
+        return {false, 0, 0, 0, 0};
+      }
+
+      unsigned max_ch;
+      if (!base::StringToUint(parts[3], &max_ch)) {
+        return {false, 0, 0, 0, 0};
+      }
+
+      return {true, static_cast<float>(sample_rate_d), base_lat, output_lat,
+              static_cast<uint32_t>(max_ch)};
+    }
+
+    if (cl->HasSwitch(switches::kFingerprintPlatform)) {
+      std::string platform = base::ToLowerASCII(
+          cl->GetSwitchValueASCII(switches::kFingerprintPlatform));
+      if (platform == "macos") {
+        return {true, 48000.0f, 0.005333, 0.0, 2};
+      }
+      if (platform == "windows" || platform == "linux") {
+        return {true, 48000.0f, 0.01, 0.0, 2};
+      }
+    }
+
+    return {false, 0, 0, 0, 0};
+  }();
+  return ovr;
+}
+
+}  // namespace nodriver4j
+
+#endif  // COMPONENTS_NODRIVER4J_AUDIO_OVERRIDE_H_
