+// Generate a deterministic frame count adjustment based on the audio fingerprint seed
+static uint32_t GetAudioNoiseFrames(uint32_t number_of_frames) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(switches::kAudioFingerprint))
+    return 0;
+
+  std::string seed_str =
+      command_line->GetSwitchValueASCII(switches::kAudioFingerprint);
+  if (seed_str.empty())
+    return 0;
+
+  std::string combined = seed_str + std::to_string(number_of_frames) + "audio";
+  uint32_t hash = static_cast<uint32_t>(std::hash<std::string>{}(combined));
+
+  // Noise is 1 to min(1% of frames, 1000)
+  uint32_t one_percent = number_of_frames / 100;
+  if (one_percent < 1) one_percent = 1;
+
+  uint32_t noise_limit = std::min(one_percent, 1000u);
+  return (hash % noise_limit) + 1;
+}
