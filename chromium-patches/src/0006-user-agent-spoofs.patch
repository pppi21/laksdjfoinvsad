     "//components/policy/core/common",
     "//components/prefs",
     "//components/version_info",
diff --git a/components/embedder_support/user_agent_utils.cc b/components/embedder_support/user_agent_utils.cc
index 557eadb182..7277cab117 100644
--- a/components/embedder_support/user_agent_utils.cc
+++ b/components/embedder_support/user_agent_utils.cc
@@ -34,6 +34,8 @@
 #include "net/http/http_util.h"
 #include "third_party/blink/public/common/features.h"
 #include "third_party/blink/public/common/user_agent/user_agent_metadata.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
+#include "third_party/blink/public/common/user_agent/user_agent_metadata.h"
 
 #if BUILDFLAG(IS_WIN)
 #include <windows.h>
@@ -215,9 +217,6 @@ const blink::UserAgentBrandList GetUserAgentBrandFullVersionListInternal(
 // depending on the Reduce User-Agent reduction phase features.
 std::string GetUserAgentInternal() {
   std::string product = GetProductAndVersion();
-  if (base::CommandLine::ForCurrentProcess()->HasSwitch(kHeadless)) {
-    product.insert(0, "Headless");
-  }
 
 #if BUILDFLAG(IS_ANDROID) || BUILDFLAG(IS_IOS)
   if (base::CommandLine::ForCurrentProcess()->HasSwitch(kUseMobileUserAgent)) {
@@ -225,9 +224,12 @@ std::string GetUserAgentInternal() {
   }
 #endif
 
-  return ShouldSendUserAgentUnifiedPlatform()
+  std::string user_agent = ShouldSendUserAgentUnifiedPlatform()
              ? BuildUnifiedPlatformUserAgentFromProduct(product)
              : BuildUserAgentFromProduct(product);
+
+  user_agent += blink::GetUserAgentFingerprintBrandInfo();
+  return user_agent;
 }
 
 // Generate random order list based on the input size and seed.
@@ -279,6 +281,19 @@ blink::UserAgentBrandList ShuffleBrandList(
 }
 
 std::string GetUserAgentPlatform() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kFingerprintPlatform)) {
+    std::string platform_key = base::ToLowerASCII(
+        command_line->GetSwitchValueASCII(switches::kFingerprintPlatform));
+    if (platform_key == "windows") {
+      return "";
+    } else if (platform_key == "linux") {
+      return "X11; ";
+    } else if (platform_key == "macos") {
+      return "Macintosh; ";
+    }
+  }
 #if BUILDFLAG(IS_WIN)
   return "";
 #elif BUILDFLAG(IS_MAC)
@@ -299,6 +314,19 @@ std::string GetUserAgentPlatform() {
 }
 
 std::string GetUnifiedPlatform() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kFingerprintPlatform)) {
+    std::string platform_key = base::ToLowerASCII(
+        command_line->GetSwitchValueASCII(switches::kFingerprintPlatform));
+    if (platform_key == "windows") {
+      return "Windows NT 10.0; Win64; x64";
+    } else if (platform_key == "linux") {
+      return "X11; Linux x86_64";
+    } else if (platform_key == "macos") {
+      return "Macintosh; Intel Mac OS X 10_15_7";
+    }
+  }
 #if BUILDFLAG(IS_ANDROID) || BUILDFLAG(IS_LINUX)
   // This constant is only used on Android (desktop) and Linux.
   constexpr char kUnifiedPlatformLinuxX64[] = "X11; Linux x86_64";
