 namespace blink {
 
+namespace {
+
+struct ScreenOverride {
+  int width;
+  int height;
+  int avail_width;
+  int avail_height;
+  int avail_top;
+  int color_depth;
+};
+
+std::optional<ScreenOverride> ParseScreenOverride() {
+  const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+  if (!cl->HasSwitch(::switches::kFingerprintScreen))
+    return std::nullopt;
+
+  std::string value = cl->GetSwitchValueASCII(::switches::kFingerprintScreen);
+  std::vector<std::string> parts = base::SplitString(
+      value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+  if (parts.size() != 6)
+    return std::nullopt;
+
+  ScreenOverride result;
+  if (!base::StringToInt(parts[0], &result.width) ||
+      !base::StringToInt(parts[1], &result.height) ||
+      !base::StringToInt(parts[2], &result.avail_width) ||
+      !base::StringToInt(parts[3], &result.avail_height) ||
+      !base::StringToInt(parts[4], &result.avail_top) ||
+      !base::StringToInt(parts[5], &result.color_depth))
+    return std::nullopt;
+
+  return result;
+}
+
+}  // namespace
+
 Screen::Screen(LocalDOMWindow* window, int64_t display_id)
     : ExecutionContextClient(window), display_id_(display_id) {}
 
