+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintBrandVersionLong[];
+
+// GPU spoofing
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintGpuVendor[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintGpuRenderer[];
+
+// Hardware
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintDeviceMemory[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintHardwareConcurrency[];
+
+// Media device count override: "mics,webcams,speakers" (e.g. "1,1,3")
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintMedia[];
+
+// OS spoofing
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintPlatform[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintPlatformVersion[];
+
+// Timezone spoofing
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintTimezone[];
+
+// Geolocation spoofing: "latitude,longitude,accuracy"
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintGeolocation[];
+
+// Canvas and audio fingerprint seeds
+COMPONENT_EXPORT(NODRIVER4J) extern const char kCanvasFingerprint[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kAudioFingerprint[];
+
+// Screen geometry: "width,height,availWidth,availHeight,availTop,colorDepth[,devicePixelRatio]"
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintScreen[];
+
+// Window position on screen: "x,y"
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintScreenPosition[];
+
+// Session history length
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintHistoryLength[];
+
+// AudioContext properties: "sampleRate,baseLatency,outputLatency,maxChannelCount"
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintAudioContext[];
+
+// Battery status: "charging,level,chargingTime,dischargingTime"
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintBattery[];
+
+// WebRTC IP spoofing
+COMPONENT_EXPORT(NODRIVER4J) extern const char kWebrtcIP4[];
+COMPONENT_EXPORT(NODRIVER4J) extern const char kWebrtcIP6[];
+
+// Network connection override: "effectiveType,downlink,rtt,saveData,type"
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintConnection[];
+
+// CSS media feature overrides: "colorScheme,reducedMotion,contrast,forcedColors,colorGamut"
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintMediaFeatures[];
+
+// X-Client-Data header override
+COMPONENT_EXPORT(NODRIVER4J) extern const char kXClientData[];
+
+// Request Header Integrity override
+COMPONENT_EXPORT(NODRIVER4J) extern const char kFingerprintRequestIntegrity[];
+
+}  // namespace switches
+
+#endif  // COMPONENTS_NODRIVER4J_NODRIVER4J_SWITCHES_H_
