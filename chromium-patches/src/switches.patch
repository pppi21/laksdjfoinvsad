index 0000000000..9c81922350
--- /dev/null
+++ b/components/nodriver4j/nodriver4j_switches.cc
@@ -0,0 +1,81 @@
+// components\nodriver4j\nodriver4j_switches.cc
+#include "components/nodriver4j/nodriver4j_switches.h"
+
+namespace switches {
+
+// Specify the browser brand (e.g. "Chrome")
+const char kFingerprintBrand[] = "fingerprint-brand";
+
+// Specify the browser major version (e.g. "145")
+const char kFingerprintBrandVersion[] = "fingerprint-brand-version";
+
+// Specify the full browser version (e.g. "145.0.7309.92")
+const char kFingerprintBrandVersionLong[] = "fingerprint-brand-version-long";
+
+// Specify the GPU vendor string for WebGL
+const char kFingerprintGpuVendor[] = "fingerprint-gpu-vendor";
+
+// Specify the GPU renderer string for WebGL
+const char kFingerprintGpuRenderer[] = "fingerprint-gpu-renderer";
+
+// Override device memory (GB) reported to websites
+const char kFingerprintDeviceMemory[] = "fingerprint-device-memory";
+
+// Specify the number of CPU cores for navigator.hardwareConcurrency
+const char kFingerprintHardwareConcurrency[] = "fingerprint-hardware-concurrency";
+
+// Media device count override: "mics,webcams,speakers"
+const char kFingerprintMedia[] = "fingerprint-media";
+
+// Specify the operating system (e.g. "Windows", "macOS", "Linux")
+const char kFingerprintPlatform[] = "fingerprint-platform";
+
+// Specify the operating system version (e.g. "15.0.0")
+const char kFingerprintPlatformVersion[] = "fingerprint-platform-version";
+
+// Seed for deterministic canvas fingerprint noise
+const char kCanvasFingerprint[] = "canvas-fingerprint";
+
+// Seed for deterministic audio fingerprint noise
+const char kAudioFingerprint[] = "audio-fingerprint";
+
+// Specify the IANA timezone (e.g. "America/New_York", "Asia/Tokyo")
+const char kFingerprintTimezone[] = "fingerprint-timezone";
+
+// Geolocation spoofing: "latitude,longitude,accuracy"
+const char kFingerprintGeolocation[] = "fingerprint-geolocation";
+
+// Screen geometry override: "width,height,availWidth,availHeight,availTop,colorDepth[,devicePixelRatio]"
+const char kFingerprintScreen[] = "fingerprint-screen";
+
+// Window screen position override: "x,y"
+const char kFingerprintScreenPosition[] = "fingerprint-screen-position";
+
+// Override for history.length
+const char kFingerprintHistoryLength[] = "fingerprint-history-length";
+
+// AudioContext properties: "sampleRate,baseLatency,outputLatency,maxChannelCount"
+const char kFingerprintAudioContext[] = "fingerprint-audio-context";
+
+// Battery status: "charging,level,chargingTime,dischargingTime"
+const char kFingerprintBattery[] = "fingerprint-battery";
+
+// WebRTC IPv4 address to use in ICE candidates and SDP
+const char kWebrtcIP4[] = "webrtc-ip4";
+
+// WebRTC IPv6 address to use in ICE candidates and SDP
+const char kWebrtcIP6[] = "webrtc-ip6";
+
+// Network connection override: "effectiveType,downlink,rtt,saveData,type"
+const char kFingerprintConnection[] = "fingerprint-connection";
+
+// CSS media feature overrides: "colorScheme,reducedMotion,contrast,forcedColors,colorGamut"
+const char kFingerprintMediaFeatures[] = "fingerprint-media-features";
+
+// Override X-Client-Data header value for Google domains
+const char kXClientData[] = "x-client-data";
+
+// Override Request Header Integrity headers for Google domains: "channel|year|validation|copyright"
+const char kFingerprintRequestIntegrity[] = "fingerprint-request-integrity";
+
+}  // namespace switches
\ No newline at end of file
