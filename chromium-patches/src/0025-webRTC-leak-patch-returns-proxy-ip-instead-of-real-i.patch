+// components/nodriver4j/webrtc_ip_spoofer.h
+//
+// Header-only utility for WebRTC IP spoofing. Provides functions to detect
+// whether spoofing is active, classify IPs as exempt (special/reserved),
+// and apply IP replacement to ICE candidate strings and SDP bodies.
+//
+// Usage: Include this header and call WebRtcIpSpoofer::SpoofCandidate() or
+// WebRtcIpSpoofer::SpoofSdp() at the relevant intercept points in Blink.
+
+#ifndef COMPONENTS_NODRIVER4J_WEBRTC_IP_SPOOFER_H_
+#define COMPONENTS_NODRIVER4J_WEBRTC_IP_SPOOFER_H_
+
+#include <sstream>
+#include <string>
+#include <vector>
+
+#include "base/command_line.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
+
+namespace nodriver4j {
+
+class WebRtcIpSpoofer {
+ public:
+  WebRtcIpSpoofer() = delete;
+
+  // Returns true if either --webrtc-ip4 or --webrtc-ip6 is set.
+  static inline bool IsActive() {
+    const auto* cmd = base::CommandLine::ForCurrentProcess();
+    return cmd->HasSwitch(switches::kWebrtcIP4) ||
+           cmd->HasSwitch(switches::kWebrtcIP6);
+  }
+
+  // Returns the IPv4 spoof address, or empty string if not set.
+  static inline std::string SpoofIPv4() {
+    return base::CommandLine::ForCurrentProcess()
+        ->GetSwitchValueASCII(switches::kWebrtcIP4);
+  }
+
+  // Returns the IPv6 spoof address, or empty string if not set.
+  static inline std::string SpoofIPv6() {
+    return base::CommandLine::ForCurrentProcess()
+        ->GetSwitchValueASCII(switches::kWebrtcIP6);
+  }
+
+  // Returns true if the address contains a colon (IPv6 notation).
+  static inline bool IsIPv6(const std::string& ip) {
+    return ip.find(':') != std::string::npos;
+  }
+
+  // Returns true if the IP is a reserved address that should not be replaced.
+  // Exempt addresses: any-address, loopback, and link-local ranges.
+  static inline bool IsSpecialIP(const std::string& ip) {
+    if (ip.empty())
+      return true;
+    // Any-address
+    if (ip == "0.0.0.0" || ip == "::")
+      return true;
+    // Loopback
+    if (ip == "127.0.0.1" || ip == "::1")
+      return true;
+    // Link-local IPv4 (169.254.0.0/16)
+    if (ip.compare(0, 8, "169.254.") == 0)
+      return true;
+    // Link-local IPv6 (fe80::/10)
+    if (ip.size() >= 4 && (ip[0] == 'f' || ip[0] == 'F') &&
+        (ip[1] == 'e' || ip[1] == 'E') && ip[2] == '8' && ip[3] == '0')
+      return true;
+    return false;
+  }
+
+  // Returns the spoof address for a given IP, or the original IP if:
+  // - The IP is a special/reserved address
+  // - No spoof is configured for this address family
+  static inline std::string ReplacementForIP(const std::string& ip) {
+    if (IsSpecialIP(ip))
+      return ip;
+    if (IsIPv6(ip)) {
+      std::string spoof = SpoofIPv6();
+      return spoof.empty() ? ip : spoof;
+    }
+    std::string spoof = SpoofIPv4();
+    return spoof.empty() ? ip : spoof;
+  }
+
+  // Replaces IP addresses in an ICE candidate string.
+  //
+  // Handles both bare candidates ("candidate:...") and SDP-prefixed
+  // candidates ("a=candidate:..."). Replaces the connection address at
+  // token index 4 and any related address following the "raddr" keyword.
+  //
+  // ICE candidate format (RFC 5245):
+  //   candidate:foundation component transport priority address port
+  //   typ type [raddr addr rport port] [generation ...]
+  static inline std::string SpoofCandidate(const std::string& candidate) {
+    if (!IsActive() || candidate.empty())
+      return candidate;
+
+    // Tokenize by whitespace
+    std::vector<std::string> tokens;
+    std::istringstream iss(candidate);
+    std::string token;
+    while (iss >> token) {
+      tokens.push_back(token);
+    }
+
+    // Need at least 5 tokens to contain an address field
+    if (tokens.size() < 5)
+      return candidate;
+
+    // Connection address is always at index 4
+    tokens[4] = ReplacementForIP(tokens[4]);
+
+    // Replace related address if present (follows "raddr" keyword)
+    for (size_t i = 0; i + 1 < tokens.size(); ++i) {
+      if (tokens[i] == "raddr") {
+        tokens[i + 1] = ReplacementForIP(tokens[i + 1]);
+      }
+    }
+
+    // Reconstruct the candidate string
+    std::string result;
+    for (size_t i = 0; i < tokens.size(); ++i) {
+      if (i > 0)
+        result += ' ';
+      result += tokens[i];
+    }
+    return result;
+  }
+
+  // Replaces IP addresses in a full SDP body.
+  //
+  // Processes three types of SDP lines:
+  //   - a=candidate: lines — delegates to SpoofCandidate()
+  //   - c= connection lines — address at field 2 (c=IN IP4 <addr>)
+  //   - o= origin lines — address at token index 5
+  //     (o=<user> <id> <ver> IN IP4 <addr>)
+  //
+  // Preserves original line endings (\r\n or \n).
+  static inline std::string SpoofSdp(const std::string& sdp) {
+    if (!IsActive() || sdp.empty())
+      return sdp;
+
+    std::istringstream iss(sdp);
+    std::ostringstream oss;
+    std::string line;
+
+    while (std::getline(iss, line)) {
+      // Preserve \r if present (SDP uses \r\n line endings)
+      bool had_cr = (!line.empty() && line.back() == '\r');
+      if (had_cr)
+        line.pop_back();
+
+      if (line.compare(0, 12, "a=candidate:") == 0) {
+        line = SpoofCandidate(line);
+
+      } else if (line.compare(0, 2, "c=") == 0) {
+        // Connection line: c=IN IP4 <address> or c=IN IP6 <address>
+        auto space1 = line.find(' ');
+        if (space1 != std::string::npos) {
+          auto space2 = line.find(' ', space1 + 1);
+          if (space2 != std::string::npos) {
+            std::string addr = line.substr(space2 + 1);
+            line = line.substr(0, space2 + 1) + ReplacementForIP(addr);
+          }
+        }
+
+      } else if (line.compare(0, 2, "o=") == 0) {
+        // Origin line: o=<user> <sess-id> <sess-ver> IN IP4/IP6 <address>
+        // Address is at token index 5
+        std::vector<std::string> tokens;
+        std::istringstream liss(line);
+        std::string tok;
+        while (liss >> tok)
+          tokens.push_back(tok);
+        if (tokens.size() >= 6) {
+          tokens[5] = ReplacementForIP(tokens[5]);
+          line.clear();
+          for (size_t i = 0; i < tokens.size(); ++i) {
+            if (i > 0)
+              line += ' ';
+            line += tokens[i];
+          }
+        }
+      }
+
+      oss << line;
+      if (had_cr)
+        oss << '\r';
+      oss << '\n';
+    }
+
+    return oss.str();
+  }
+};
+
+}  // namespace nodriver4j
+
+#endif  // COMPONENTS_NODRIVER4J_WEBRTC_IP_SPOOFER_H_
