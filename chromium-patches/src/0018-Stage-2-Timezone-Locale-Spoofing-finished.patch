       switches::kFingerprintPlatformVersion,
       switches::kCanvasFingerprint,
       switches::kAudioFingerprint,
+      switches::kFingerprintTimezone,
       switches::kFingerprintScreen,
       switches::kFingerprintScreenPosition,
       switches::kFingerprintHistoryLength,
