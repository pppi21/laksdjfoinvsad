-void StaticBitmapImage::ShuffleSubchannelColorData(const void* addr,
-                                                    const SkImageInfo& info,
-                                                    int srcX,
-                                                    int srcY) {
-  int w = info.width() - srcX;
-  int h = info.height() - srcY;
-
-  if (w < 8 || h < 8) {
-    return;
-  }
-
-  std::string seed_str = "0";
-  const base::CommandLine* command_line =
-      base::CommandLine::ForCurrentProcess();
-  if (command_line->HasSwitch(switches::kCanvasFingerprint)) {
-    seed_str =
-        command_line->GetSwitchValueASCII(switches::kCanvasFingerprint);
-  }
-
-  auto colorType = info.colorType();
-  auto fRowBytes = info.minRowBytes();
-
-  // Only handle the formats Chromium actually uses for canvas
-  if (colorType != kRGBA_8888_SkColorType &&
-      colorType != kBGRA_8888_SkColorType) {
-    return;
-  }
-
-  // --- Pass 1: Collect anti-aliased transition pixel indices ---
-  // Only pixels where neighbor difference is SMALL (anti-aliasing zones).
-  // Hard edges (solid fill boundaries) have large differences and are skipped.
-  std::vector<int> edge_indices;
-  edge_indices.reserve(256);
-
-  for (int y = 0; y < h; y++) {
-    for (int x = 0; x < w; x++) {
-      auto* current = (uint32_t*)((const char*)addr + y * fRowBytes + x * sizeof(uint32_t));
-
-      auto a = SkGetPackedA32(*current);
-      if (a == 0) continue;
-
-      int cr, cg, cb;
-      if (colorType == kRGBA_8888_SkColorType) {
-        cr = SkGetPackedR32(*current);
-        cg = SkGetPackedG32(*current);
-        cb = SkGetPackedB32(*current);
-      } else {
-        cb = SkGetPackedR32(*current);
-        cg = SkGetPackedG32(*current);
-        cr = SkGetPackedB32(*current);
-      }
-
-      bool is_transition = false;
-
-      // Check right neighbor
-      if (x < w - 1) {
-        auto* right = (uint32_t*)((const char*)addr + y * fRowBytes + (x + 1) * sizeof(uint32_t));
-        if (*current != *right) {
-          int rr, rg, rb;
-          if (colorType == kRGBA_8888_SkColorType) {
-            rr = SkGetPackedR32(*right);
-            rg = SkGetPackedG32(*right);
-            rb = SkGetPackedB32(*right);
-          } else {
-            rb = SkGetPackedR32(*right);
-            rg = SkGetPackedG32(*right);
-            rr = SkGetPackedB32(*right);
-          }
-          int diff = std::abs(cr - rr) + std::abs(cg - rg) + std::abs(cb - rb);
-          // Small difference = anti-aliasing zone (1-80 total across 3 channels)
-          // Large difference = hard edge (solid fill boundary) — skip
-          if (diff >= 1 && diff <= 80) {
-            is_transition = true;
-          }
-        }
-      }
-
-      // Check bottom neighbor
-      if (!is_transition && y < h - 1) {
-        auto* bottom = (uint32_t*)((const char*)addr + (y + 1) * fRowBytes + x * sizeof(uint32_t));
-        if (*current != *bottom) {
-          int br, bg, bb;
-          if (colorType == kRGBA_8888_SkColorType) {
-            br = SkGetPackedR32(*bottom);
-            bg = SkGetPackedG32(*bottom);
-            bb = SkGetPackedB32(*bottom);
-          } else {
-            bb = SkGetPackedR32(*bottom);
-            bg = SkGetPackedG32(*bottom);
-            br = SkGetPackedB32(*bottom);
-          }
-          int diff = std::abs(cr - br) + std::abs(cg - bg) + std::abs(cb - bb);
-          if (diff >= 1 && diff <= 80) {
-            is_transition = true;
-          }
-        }
-      }
-
-      if (is_transition) {
-        edge_indices.push_back(y * w + x);
-      }
-    }
-  }
-
-  if (edge_indices.empty()) {
-    return;
-  }
-
-  // --- Pass 2: Select a pseudo-random subset of edge pixels to modify ---
-  size_t master_hash = std::hash<std::string>{}(seed_str + "_canvas");
-
-  // Modify 2-8% of edge pixels (varies by seed), capped at 150
-  double rate = 0.02 + (double)(master_hash % 60) / 1000.0;
-  int target = static_cast<int>(edge_indices.size() * rate);
-  if (target < 2) target = 2;
-  if (target > 150) target = 150;
-  if (target > (int)edge_indices.size()) target = (int)edge_indices.size();
-
-  // Fisher-Yates partial shuffle using hash chain to pick which edge pixels to modify
-  size_t hash_state = std::hash<std::string>{}(seed_str + "_sel");
-  int edge_count = (int)edge_indices.size();
-
-  for (int i = 0; i < target; i++) {
-    hash_state = hash_state * 6364136223846793005ULL + 1442695040888963407ULL;
-    int j = i + (int)(hash_state % (edge_count - i));
-    std::swap(edge_indices[i], edge_indices[j]);
-  }
-
-  // --- Pass 3: Apply ±1 noise to selected edge pixels ---
-  for (int i = 0; i < target; i++) {
-    int idx = edge_indices[i];
-    int x = idx % w;
-    int y = idx / w;
-
-    // Per-pixel hash for channel selection and direction
-    size_t pixel_hash = std::hash<std::string>{}(
-        seed_str + "_p" + std::to_string(idx));
-
-    // Each channel: ~60% chance of being modified
-    bool mod_r = (pixel_hash & 0x7) >= 3;
-    bool mod_g = ((pixel_hash >> 3) & 0x7) >= 3;
-    bool mod_b = ((pixel_hash >> 6) & 0x7) >= 3;
-    if (!mod_r && !mod_g && !mod_b) mod_r = true;
-
-    int dr = ((pixel_hash >> 9) & 1) ? 1 : -1;
-    int dg = ((pixel_hash >> 10) & 1) ? 1 : -1;
-    int db = ((pixel_hash >> 11) & 1) ? 1 : -1;
-
-    auto* pixel = (uint32_t*)((const char*)addr + y * fRowBytes + x * sizeof(uint32_t));
-
-    if (colorType == kRGBA_8888_SkColorType) {
-      int r = SkGetPackedR32(*pixel);
-      int g = SkGetPackedG32(*pixel);
-      int b = SkGetPackedB32(*pixel);
-      auto a = SkGetPackedA32(*pixel);
-
-      if (mod_r) r = std::clamp(r + dr, 0, 255);
-      if (mod_g) g = std::clamp(g + dg, 0, 255);
-      if (mod_b) b = std::clamp(b + db, 0, 255);
-
-      *pixel = (a << SK_A32_SHIFT) | (r << SK_R32_SHIFT) |
-               (g << SK_G32_SHIFT) | (b << SK_B32_SHIFT);
-    } else {  // kBGRA_8888_SkColorType
-      int b = SkGetPackedR32(*pixel);
-      int g = SkGetPackedG32(*pixel);
-      int r = SkGetPackedB32(*pixel);
-      auto a = SkGetPackedA32(*pixel);
-
-      if (mod_r) r = std::clamp(r + dr, 0, 255);
-      if (mod_g) g = std::clamp(g + dg, 0, 255);
-      if (mod_b) b = std::clamp(b + db, 0, 255);
-
-      *pixel = (a << SK_BGRA_A32_SHIFT) | (r << SK_BGRA_R32_SHIFT) |
-               (g << SK_BGRA_G32_SHIFT) | (b << SK_BGRA_B32_SHIFT);
-    }
-  }
-}
-
 }  // namespace blink
