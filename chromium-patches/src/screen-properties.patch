+struct ScreenPositionCache {
+  bool active;
+  int x;
+  int y;
+};
+
+const ScreenPositionCache& GetScreenPosition() {
+  static const ScreenPositionCache cache = []() -> ScreenPositionCache {
+    const base::CommandLine* cl = base::CommandLine::ForCurrentProcess();
+    if (!cl->HasSwitch(::switches::kFingerprintScreenPosition))
+      return {false, 0, 0};
+    std::string value =
+        cl->GetSwitchValueASCII(::switches::kFingerprintScreenPosition);
+    std::vector<std::string> parts = base::SplitString(
+        value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+    int x = 0, y = 0;
+    if (parts.size() == 2 && base::StringToInt(parts[0], &x) &&
+        base::StringToInt(parts[1], &y))
+      return {true, x, y};
+    return {false, 0, 0};
+  }();
+  return cache;
+}
