+struct CachedUAOverride {
+  bool active;
+  std::vector<UserAgentBrandVersion> brand_version_list;
+  std::vector<UserAgentBrandVersion> brand_full_version_list;
+  std::string full_version;
+  std::string platform;
+  std::string platform_version;
+  std::string architecture;
+  std::string bitness;
+  bool wow64;
+};
+
+const CachedUAOverride& GetCachedUAOverride() {
+  static const base::NoDestructor<CachedUAOverride> cached([]() -> CachedUAOverride {
+    const base::CommandLine* command_line =
+        base::CommandLine::ForCurrentProcess();
+
+    if (!command_line->HasSwitch(switches::kFingerprintBrandVersion) &&
+        !command_line->HasSwitch(switches::kFingerprintBrandVersionLong) &&
+        !command_line->HasSwitch(switches::kFingerprintPlatform))
+      return {false, {}, {}, "", "", "", "", "", false};
+
+    // Build a dummy metadata and run the full override logic once
+    UserAgentMetadata seed;
+    // Provide a Chromium entry so the extraction loop finds it
+    seed.brand_full_version_list.push_back({"Chromium", PRODUCT_VERSION});
+    seed.full_version = PRODUCT_VERSION;
+
+    // --- Extract Chromium info ---
+    std::string chromium_full_version;
+    std::string chromium_major_version;
+    for (const auto& entry : seed.brand_full_version_list) {
+      if (entry.brand == "Chromium") {
+        chromium_full_version = entry.version;
+        size_t dot = chromium_full_version.find('.');
+        chromium_major_version = (dot != std::string::npos)
+                                     ? chromium_full_version.substr(0, dot)
+                                     : chromium_full_version;
+        break;
+      }
+    }
+
+    // --- Determine display brand ---
+    std::string display_brand;
+    if (command_line->HasSwitch(switches::kFingerprintBrand)) {
+      std::string brand_key =
+          command_line->GetSwitchValueASCII(switches::kFingerprintBrand);
+      if (brand_key == "Chrome") display_brand = "Google Chrome";
+      else if (brand_key == "Edge") display_brand = "Microsoft Edge";
+      else if (brand_key == "Opera") display_brand = "Opera";
+      else if (brand_key == "Vivaldi") display_brand = "Vivaldi";
+      else display_brand = brand_key;
+    } else {
+      display_brand = "Google Chrome";
+    }
+
+    // --- Resolve versions ---
+    std::string brand_full_version;
+    std::string brand_major_version;
+
+    if (command_line->HasSwitch(switches::kFingerprintBrandVersionLong)) {
+      brand_full_version = command_line->GetSwitchValueASCII(
+          switches::kFingerprintBrandVersionLong);
+    } else if (command_line->HasSwitch(switches::kFingerprintBrandVersion)) {
+      brand_full_version =
+          command_line->GetSwitchValueASCII(switches::kFingerprintBrandVersion) +
+          ".0.0.0";
+    } else {
+      brand_full_version = chromium_full_version;
+    }
+
+    if (command_line->HasSwitch(switches::kFingerprintBrandVersion)) {
+      brand_major_version =
+          command_line->GetSwitchValueASCII(switches::kFingerprintBrandVersion);
+    } else {
+      size_t dot = brand_full_version.find('.');
+      brand_major_version = (dot != std::string::npos)
+                                ? brand_full_version.substr(0, dot)
+                                : brand_full_version;
+    }
+
+    chromium_major_version = brand_major_version;
+    chromium_full_version = brand_full_version;
+
+    // --- GREASE ---
+    int grease_seed = 0;
+    base::StringToInt(brand_major_version, &grease_seed);
+
+    const std::vector<std::string> grease_chars = {
+        " ", "(", ":", "-", ".", "/", ")", ";", "=", "?", "_"};
+    const std::vector<std::string> grease_versions = {"8", "99", "24"};
+
+    std::string not_a_brand = base::StrCat({
+        "Not",
+        grease_chars[grease_seed % grease_chars.size()],
+        "A",
+        grease_chars[(grease_seed + 1) % grease_chars.size()],
+        "Brand"});
+    std::string not_a_brand_major = grease_versions[grease_seed % grease_versions.size()];
+    std::string not_a_brand_full = not_a_brand_major + ".0.0.0";
+
+    CachedUAOverride result;
+    result.active = true;
+
+    result.brand_version_list.push_back({not_a_brand, not_a_brand_major});
+    result.brand_version_list.push_back({display_brand, brand_major_version});
+    result.brand_version_list.push_back({"Chromium", chromium_major_version});
+
+    result.brand_full_version_list.push_back({not_a_brand, not_a_brand_full});
+    result.brand_full_version_list.push_back({display_brand, brand_full_version});
+    result.brand_full_version_list.push_back({"Chromium", chromium_full_version});
+
+    result.full_version = brand_full_version;
+
+    // --- Platform ---
+    if (command_line->HasSwitch(switches::kFingerprintPlatform)) {
+      std::string platform_key = base::ToLowerASCII(
+          command_line->GetSwitchValueASCII(switches::kFingerprintPlatform));
+
+      if (platform_key == "windows") {
+        result.platform = "Windows";
+        result.platform_version = "19.0.0";
+        result.architecture = "x86";
+        result.bitness = "64";
+        result.wow64 = false;
+      } else if (platform_key == "linux") {
+        result.platform = "Linux";
+        result.platform_version = "6.11.0";
+        result.architecture = "x86";
+        result.bitness = "64";
+        result.wow64 = false;
+      } else if (platform_key == "macos") {
+        result.platform = "macOS";
+        result.platform_version = "15.2.0";
+        result.architecture = "arm";
+        result.bitness = "64";
+        result.wow64 = false;
+      }
+
+      if (command_line->HasSwitch(switches::kFingerprintPlatformVersion)) {
+        std::string v = command_line->GetSwitchValueASCII(
+            switches::kFingerprintPlatformVersion);
+        if (!v.empty())
+          result.platform_version = v;
+      }
+    }
+
+    return result;
+  }());
+  return *cached;
+}
+
+
