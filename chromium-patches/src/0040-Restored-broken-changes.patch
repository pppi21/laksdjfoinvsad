+#ifndef COMPONENTS_NODRIVER4J_GOOGLE_DOMAIN_UTIL_H_
+#define COMPONENTS_NODRIVER4J_GOOGLE_DOMAIN_UTIL_H_
+
+#include <string_view>
+
+#include "url/gurl.h"
+
+namespace nodriver4j {
+
+// Lightweight Google-associated domain check used exclusively by our
+// spoofing infrastructure (X-Client-Data, Request Header Integrity).
+// Chrome's own google_util::IsGoogleAssociatedDomainUrl() is intentionally
+// gutted to prevent Chrome from treating Google domains specially.
+// This function exists so our fingerprint-spoofing headers still reach
+// the correct destinations.
+inline bool IsGoogleAssociatedDomain(const GURL& url) {
+  if (!url.is_valid() || !url.SchemeIsHTTPOrHTTPS()) {
+    return false;
+  }
+
+    const std::string_view host = url.host();
+
+  // Google TLD variants (google.com, google.co.uk, google.de, etc.)
+  // We match any host ending in "google." followed by a TLD component.
+  // This intentionally uses suffix matching rather than a full TLD list
+  // to keep maintenance burden near zero.
+  static constexpr std::string_view kGoogleSuffixes[] = {
+      ".google.com",        ".google.co.uk",     ".google.ca",
+      ".google.com.au",     ".google.de",        ".google.fr",
+      ".google.co.jp",      ".google.it",        ".google.es",
+      ".google.com.br",     ".google.co.in",     ".google.ru",
+      ".google.nl",         ".google.pl",        ".google.co.kr",
+  };
+
+  static constexpr std::string_view kAssociatedSuffixes[] = {
+      ".youtube.com",
+      ".ytimg.com",
+      ".doubleclick.com",
+      ".doubleclick.net",
+      ".ggpht.com",
+      ".googleadservices.com",
+      ".googleapis.com",
+      ".googlesyndication.com",
+      ".googleusercontent.com",
+      ".googlevideo.com",
+      ".gstatic.com",
+      ".youtubekids.com",
+      ".google-analytics.com",
+      ".gmail.com",
+  };
+
+  // Exact match for bare google.com / youtube.com etc.
+  if (host == "google.com" || host == "youtube.com" || host == "gmail.com" ||
+      host == "googleapis.com" || host == "gstatic.com") {
+    return true;
+  }
+
+  for (const auto& suffix : kGoogleSuffixes) {
+    if (host.size() > suffix.size() && host.ends_with(suffix)) {
+      return true;
+    }
+    // Also match the bare domain (e.g. "google.com" without subdomain).
+    if (host == suffix.substr(1)) {
+      return true;
+    }
+  }
+
+  for (const auto& suffix : kAssociatedSuffixes) {
+    if (host.size() > suffix.size() && host.ends_with(suffix)) {
+      return true;
+    }
+    if (host == suffix.substr(1)) {
+      return true;
+    }
+  }
+
+  return false;
+}
+
+}  // namespace nodriver4j
+
+#endif  // COMPONENTS_NODRIVER4J_GOOGLE_DOMAIN_UTIL_H_
