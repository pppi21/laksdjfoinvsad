diff --git a/third_party/blink/renderer/core/geolocation/geolocation_coordinates.cc b/third_party/blink/renderer/core/geolocation/geolocation_coordinates.cc
index 4c5336c6a6..001094284f 100644
--- a/third_party/blink/renderer/core/geolocation/geolocation_coordinates.cc
+++ b/third_party/blink/renderer/core/geolocation/geolocation_coordinates.cc
@@ -25,15 +25,74 @@
 
 #include "third_party/blink/renderer/core/geolocation/geolocation_coordinates.h"
 
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_split.h"
+#include "components/nodriver4j/nodriver4j_switches.h"
 #include "third_party/blink/renderer/bindings/core/v8/v8_object_builder.h"
 
 namespace blink {
 
+namespace {
+
+struct GeoOverride {
+  double latitude;
+  double longitude;
+  double accuracy;
+  bool valid;
+};
+
+// Parse once per process and cache the result.
+const GeoOverride& GetGeoOverride() {
+  static const GeoOverride override = []() -> GeoOverride {
+    const std::string value =
+        base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+            switches::kFingerprintGeolocation);
+    if (value.empty())
+      return {0, 0, 0, false};
+
+    std::vector<std::string> parts = base::SplitString(
+        value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+    if (parts.size() < 2)
+      return {0, 0, 0, false};
+
+    double lat, lon;
+    if (!base::StringToDouble(parts[0], &lat) ||
+        !base::StringToDouble(parts[1], &lon)) {
+      return {0, 0, 0, false};
+    }
+
+    double acc = 0;
+    if (parts.size() >= 3)
+      base::StringToDouble(parts[2], &acc);
+
+    return {lat, lon, acc, true};
+  }();
+  return override;
+}
+
+}  // namespace
+
+double GeolocationCoordinates::latitude() const {
+  const auto& geo = GetGeoOverride();
+  return geo.valid ? geo.latitude : latitude_;
+}
+
+double GeolocationCoordinates::longitude() const {
+  const auto& geo = GetGeoOverride();
+  return geo.valid ? geo.longitude : longitude_;
+}
+
+double GeolocationCoordinates::accuracy() const {
+  const auto& geo = GetGeoOverride();
+  return (geo.valid && geo.accuracy > 0) ? geo.accuracy : accuracy_;
+}
+
 ScriptObject GeolocationCoordinates::toJSON(ScriptState* script_state) const {
   V8ObjectBuilder builder(script_state);
-  builder.AddNumber("accuracy", accuracy_);
-  builder.AddNumber("latitude", latitude_);
-  builder.AddNumber("longitude", longitude_);
+  builder.AddNumber("accuracy", accuracy());
+  builder.AddNumber("latitude", latitude());
+  builder.AddNumber("longitude", longitude());
   builder.AddNumberOrNull("altitude", altitude_);
   builder.AddNumberOrNull("altitudeAccuracy", altitude_accuracy_);
   builder.AddNumberOrNull("heading", heading_);
@@ -41,4 +100,4 @@ ScriptObject GeolocationCoordinates::toJSON(ScriptState* script_state) const {
   return builder.ToScriptObject();
 }
 
-}  // namespace blink
+}  // namespace blink
